            yield Header()
            yield Container(
                OptionList(
                    Option("Bootstrap ... Set up user preferences", id="bootstrap"),
                    Option("Project ..... Create project configuration", id="project"),
                    Option("Spec ........ Generate specification", id="spec"),
                    Option("Install ..... Install deft in directory", id="install"),
                    Option("", id="sep1", disabled=True),
                    Option("Reset ....... Reset configuration files", id="reset"),
                    Option("Validate .... Check configuration", id="validate"),
                    Option("Doctor ...... Check system dependencies", id="doctor"),
                    Option("", id="sep2", disabled=True),
                    Option("README ...... View framework documentation", id="readme"),
                    Option("CHANGELOG ... View version history", id="changelog"),
                    Option("Main.md ..... View main framework guide", id="mainmd"),
                    Option("Help ........ Show help", id="help"),
                    Option("", id="sep3", disabled=True),
                    Option("Exit ........ Quit wizard", id="exit"),
                    id="menu"
                )
            )
            yield Footer()
        
        def on_option_list_option_selected(self, event: OptionList.OptionSelected) -> None:
            option_id = event.option.id
            if option_id == "exit":
                self.app.exit()
            elif option_id == "help":
                self.app.push_screen("help")
            elif option_id == "readme":
                self.app.push_screen("readme")
            elif option_id == "changelog":
                self.app.push_screen("changelog")
            elif option_id == "mainmd":
                self.app.push_screen("mainmd")
            elif option_id == "bootstrap":
                self.app.push_screen("bootstrap")
            elif option_id == "project":
                self.app.push_screen("project")
            elif option_id == "spec":
                self.app.push_screen("spec")
            elif option_id == "install":
                self.app.push_screen("install")
            elif option_id == "reset":
                self.app.push_screen("reset")
            elif option_id == "validate":
                self.app.push_screen("validate")
            elif option_id == "doctor":
                self.app.push_screen("doctor")
        
        def action_quit(self) -> None:
            self.app.exit()
    
    class BootstrapScreen(Screen):
        """Bootstrap configuration form."""
        
        BINDINGS = [("escape", "cancel", "Cancel")]
        
        CSS = """
        BootstrapScreen Horizontal {
            height: auto;
        }
        BootstrapScreen #status {
            height: auto;
        }
        """
        
        def __init__(self):
            super().__init__()
            self.available_langs = get_available_languages()
            self.available_strats = get_available_strategies()
        
        def compose(self) -> ComposeResult:
            yield Header()
            with ScrollableContainer():
                yield Label("Bootstrap - User Preferences Setup")
                yield Label("\n[dim]This section sets up your personal preferences that will apply across all projects. These settings define how the AI addresses you, your preferred languages, coverage standards, and development strategies. You only need to complete this once, though you can update it anytime.[/dim]\n")
                yield Label("Your name (how AI should address you):")
                yield Input(id="name", placeholder="Your name")
                yield Label("\nDefault coverage threshold (%):")
                yield Input(id="coverage", placeholder="85", value="85")
                yield Label("\nPrimary languages:")
                for stem, display in self.available_langs:
                    yield Checkbox(display, id=_lang_widget_id(stem))
                yield Label("Other language (optional):")
                yield Input(id="other_lang", placeholder="Enter language name")
                yield Label("\nDevelopment strategy:")
                strategy_options = [(display, stem) for stem, display in self.available_strats]
                yield Select(strategy_options, id="strategy", allow_blank=False, value=strategy_options[0][1] if strategy_options else "interview")
                yield Label("\nCustom rules (optional):")
                yield Input(id="rules", placeholder="Enter one rule — open USER.md to add more")
                yield Label("\nExperimental Rules:")
                yield Checkbox("Use meta/SOUL.md (Strategic context)", id="use_soul", value=True)
                yield Checkbox("Use meta/morals.md (Ethical AI)", id="use_morals", value=True)
                yield Checkbox("Use meta/code-field.md (Advanced arch)", id="use_code_field", value=True)
                yield Label("\nOutput location:")
                yield Input(id="output_path", placeholder="~/.config/deft/USER.md", value=get_default_paths()['user'])
            with Horizontal():
                yield Button("Submit", variant="primary", id="submit")
                yield Button("Cancel", id="cancel")
            yield Label("", id="status")
            yield Footer()
        
        def on_button_pressed(self, event: Button.Pressed) -> None:
            if event.button.id == "cancel":
                self.app.pop_screen()
            elif event.button.id == "submit":
                self.handle_submit()
        
        def action_cancel(self) -> None:
            self.app.pop_screen()
        
        def handle_submit(self) -> None:
            name = self.query_one("#name", Input).value.strip()
            coverage = self.query_one("#coverage", Input).value.strip() or "85"
            custom_rules_raw = self.query_one("#rules", Input).value.strip()
            custom_rules = f"- {custom_rules_raw}" if custom_rules_raw else ""
            
            # Get language selections from checkboxes
            languages = []
            for stem, display in self.available_langs:
                try:
                    if self.query_one(f"#{_lang_widget_id(stem)}", Checkbox).value:
                        languages.append(f"- {display}")
                except Exception:
                    pass
            other_lang = self.query_one("#other_lang", Input).value.strip()
            if other_lang:
                languages.append(f"- {other_lang}")
            languages_str = '\n'.join(languages) if languages else "- (None specified)"
            
            # Get strategy selection
            strategy_stem = str(self.query_one("#strategy", Select).value or "interview")
            strategy_display = dict(self.available_strats).get(strategy_stem, strategy_stem.title())
            
            # Get experimental rules preferences from checkboxes
            use_soul = self.query_one("#use_soul", Checkbox).value
            use_morals = self.query_one("#use_morals", Checkbox).value
            use_code_field = self.query_one("#use_code_field", Checkbox).value
            
            if not name:
                self.query_one("#status", Label).update("[red]Error: Name is required[/red]")
                return
            
            # Build experimental rules section
            experimental_rules = []
            if use_soul:
                experimental_rules.append("- ! Use meta/SOUL.md for strategic context and purpose-driven guidance")
            if use_morals:
                experimental_rules.append("- ! Use meta/morals.md for ethical AI development principles")
            if use_code_field:
                experimental_rules.append("- ~ Use meta/code-field.md for advanced architecture patterns")
            
            experimental_section = ""
            if experimental_rules:
                experimental_section = "\n## Experimental Rules\n\n" + "\n".join(experimental_rules)
            
            # Resolve output path
            output_path_str = self.query_one("#output_path", Input).value.strip()
            user_file = resolve_path(output_path_str or get_default_paths()['user'])
            # Build coverage override line (only if non-default)
            coverage_line = f"\n**Coverage**: ! ≥{coverage}% test coverage" if coverage != "85" else ""
            
            user_content = f"""# User Preferences

Legend (from RFC2119): !=MUST, ~=SHOULD, ≉=SHOULD NOT, ⊗=MUST NOT, ?=MAY.

## Personal (always wins)

Settings in this section have HIGHEST precedence — override all other deft rules,
including PROJECT.md.

**Name**: Address the user as: **{name}**

**Custom Rules**:
{custom_rules if custom_rules else "No custom rules defined yet."}

## Defaults (fallback)

Settings in this section are fallback defaults. PROJECT.md overrides these
for project-scoped settings (strategy, coverage, languages).

**Primary Languages**:
{languages_str}

**Default Strategy**: [{strategy_display}](../strategies/{strategy_stem}.md)
{coverage_line}
{experimental_section}

---

**Note**: You can edit this file anytime to update your preferences.
**See**: [../main.md](../main.md) for framework defaults.
"""
            
            user_file.parent.mkdir(parents=True, exist_ok=True)
            user_file.write_text(user_content, encoding='utf-8')
            
            self.app.push_screen(SuccessScreen(f"Created user.md at {user_file}", offer_next="project"))
    
    class ProjectScreen(Screen):
        """Project configuration form."""
        
        BINDINGS = [("escape", "cancel", "Cancel")]
        
        CSS = """
        ProjectScreen Horizontal {
            height: auto;
        }
        ProjectScreen #status {
            height: auto;
        }
        """
        
        def __init__(self):
            super().__init__()
            self.available_langs = get_available_languages()
            self.available_strats = get_available_strategies()
        
        def compose(self) -> ComposeResult:
            yield Header()
            with ScrollableContainer():
                yield Label("Project Configuration")
                yield Label("\n[dim]This section configures the specific settings for your current project. These settings override your bootstrap preferences and define project-specific details like tech stack, type, and quality standards. Complete this for each new project you work on.[/dim]\n")
                yield Label("Project name:")
                yield Input(id="name", placeholder="My Project")
                yield Label("\nProject type (select all that apply):")
                yield Checkbox("CLI", id="type_cli")
                yield Checkbox("TUI", id="type_tui")
                yield Checkbox("REST API", id="type_api")
                yield Checkbox("Web App", id="type_webapp")
                yield Checkbox("Library", id="type_library")
