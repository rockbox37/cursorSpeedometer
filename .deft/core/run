# Output helpers
def print_header(text: str):
    """Print main command header"""
    if HAS_RICH:
        console.print(Panel(f"[bold cyan]{text}[/bold cyan]", border_style="cyan"))
    else:
        print(f"\n{'=' * 60}")
        print(f"  {text}")
        print('=' * 60)

def print_section(text: str):
    """Print section header within a command"""
    if HAS_RICH:
        console.print(Markdown(f"## {text}"))
    else:
        print(f"\n{'-' * 60}")
        print(f"  {text}")
        print('-' * 60)

def print_info(msg: str):
    """Print info message"""
    if HAS_RICH:
        console.print(f"[blue]ℹ[/blue] {msg}")
    else:
        print(f"ℹ {msg}")

def print_success(msg: str):
    """Print success message"""
    if HAS_RICH:
        console.print(f"[green]✓[/green] {msg}")
    else:
        print(f"✓ {msg}")

def print_warn(msg: str):
    """Print warning message"""
    if HAS_RICH:
        console.print(f"[yellow]⚠[/yellow] {msg}")
    else:
        print(f"⚠ {msg}")

def print_error(msg: str):
    """Print error message"""
    if HAS_RICH:
        console.print(f"[red]✗[/red] {msg}")
    else:
        print(f"✗ {msg}")

# Legacy aliases for backward compatibility
info = print_info
success = print_success
warn = print_warn
error = print_error

def get_script_dir() -> Path:
    """Get the directory where this script is located"""
    return Path(__file__).parent.absolute()

def resolve_path(path_str: str) -> Path:
    """Resolve a user-supplied path string to an absolute Path.
    
    Expands ~ and resolves relative paths against cwd.
    """
    return Path(path_str).expanduser().resolve()

# ── USER.md presence gate (#163) ─────────────────────────────────────
#
# Mirrors the agentic-path USER.md gate documented in
# skills/deft-directive-build/SKILL.md ("USER.md Gate" section). The CLI
# entry points cmd_spec and cmd_project must refuse to do work when the
# user has not yet bootstrapped their preferences -- otherwise the
# generated scope vBRIEF / PROJECT-DEFINITION will lack the user-scoped
# defaults (languages, coverage, strategy) that drive downstream
# behavior. Resolution is platform-aware so that Windows and Unix users
# both find their files at the conventional XDG-ish location, while
# $DEFT_USER_PATH remains an explicit override for tests, CI, and users
# who keep deft config outside the default tree.
#
# `_resolve_user_md_path()` is the SINGLE source of truth for the
# USER.md location -- `get_default_paths()['user']` (used by
# `cmd_bootstrap` / `cmd_project` / `cmd_reset` to decide where to
# read or write USER.md) delegates to this helper so that the gate
# checks the same path bootstrap writes. Greptile P1 on PR #753
# surfaced the divergence: a Windows-aware gate paired with a
# Unix-only `get_default_paths()` default would have trapped Windows
# users in a `run bootstrap` redirect loop after a clean install
# (bootstrap writes to `C:\\Users\\<name>\\.config\\deft\\USER.md`,
# the gate then checks `%APPDATA%\\deft\\USER.md` -- different paths,
# unsatisfiable gate).

def _resolve_user_md_path() -> Path:
    """Resolve the platform-appropriate path to USER.md (#163).

    Resolution order (highest precedence first):
        1. $DEFT_USER_PATH environment variable -- honored on any platform.
        2. Windows: %APPDATA%\\deft\\USER.md
           (falls back to ~/AppData/Roaming/deft/USER.md when APPDATA is unset).
        3. Unix (macOS / Linux / *BSD): ~/.config/deft/USER.md

    Returns:
        Absolute Path to the resolved USER.md location. The file may or
        may not exist; callers (e.g. _check_user_md_gate) decide whether
        absence is fatal.
    """
    override = os.environ.get('DEFT_USER_PATH')
    if override:
        return resolve_path(override)
    if sys.platform == 'win32':
        appdata = os.environ.get('APPDATA')
        if appdata:
            return Path(appdata) / 'deft' / 'USER.md'
        # Rare on stock Windows but possible in stripped containers / CI.
        return Path.home() / 'AppData' / 'Roaming' / 'deft' / 'USER.md'
    return Path.home() / '.config' / 'deft' / 'USER.md'


def get_default_paths() -> dict:
    """Return default output paths for all generated files.

    Environment variables override built-in defaults:
        DEFT_USER_PATH          default: platform-aware (Windows:
                                %APPDATA%\\deft\\USER.md; Unix:
                                ~/.config/deft/USER.md). Resolution
                                delegates to `_resolve_user_md_path()`
                                so the path stays in sync with the
                                #163 gate -- see comment block above.
        DEFT_PROJECT_PATH       default: ./vbrief/PROJECT-DEFINITION.vbrief.json
        DEFT_PRD_PATH           default: ./PRD.md
        DEFT_SPECIFICATION_PATH default: ./SPECIFICATION.md
        DEFT_VBRIEF_PROPOSED    default: ./vbrief/proposed/

    Returns:
        dict with keys 'user', 'project', 'prd', 'specification', 'vbrief_proposed'
    """
    return {
        'user': str(_resolve_user_md_path()),
        'project': os.environ.get('DEFT_PROJECT_PATH', './vbrief/PROJECT-DEFINITION.vbrief.json'),
        'prd': os.environ.get('DEFT_PRD_PATH', './PRD.md'),
        'specification': os.environ.get('DEFT_SPECIFICATION_PATH', './SPECIFICATION.md'),
        'vbrief_proposed': os.environ.get('DEFT_VBRIEF_PROPOSED', './vbrief/proposed/'),
    }


def _check_user_md_gate() -> Optional[int]:
    """Verify USER.md exists at the platform-appropriate path (#163).

    Mirrors the agentic-path USER.md gate from
    skills/deft-directive-build/SKILL.md. When USER.md is missing the
    gate prints an actionable redirect (naming the resolved path and
    suggesting `run bootstrap`) and returns a non-zero exit code so the
    caller can propagate it via its own return value.

    Returns:
        None when USER.md exists at the resolved path -- the gate passes
        and the caller should continue with its normal flow.
        1 when USER.md is missing -- the caller MUST propagate this exit
        code (i.e. `return _check_user_md_gate() or ...` or an explicit
        early return) so the CLI exits non-zero before doing work that
        depends on user preferences.
    """
    user_path = _resolve_user_md_path()
    if user_path.exists():
        return None
    print_error(f"USER.md not found at {user_path}")
    print_info("Run 'run bootstrap' to create your user preferences before continuing.")
    print_info("Set $DEFT_USER_PATH to override the default location.")
    return 1

# ── Resume / atomic-write helpers (issue #8) ─────────────────────────

def _progress_path(output_file: Path) -> Path:
    """Return the progress-file path for a given output file.

    Convention: .{filename}.progress in the same directory.
    """
    return output_file.parent / f".{output_file.name}.progress"

def _save_progress(prog_file: Path, data: dict):
    """Persist questionnaire progress to a JSON file (best-effort)."""
    try:
        prog_file.parent.mkdir(parents=True, exist_ok=True)
        tmp = prog_file.parent / f".{prog_file.name}.tmp"
        tmp.write_text(json.dumps(data, indent=2), encoding='utf-8')
        os.replace(str(tmp), str(prog_file))
    except OSError:
        pass

def _load_progress(prog_file: Path) -> dict:
    """Load saved questionnaire progress.  Returns {} on missing/corrupt file."""
    if not prog_file.exists():
        return {}
    try:
        return json.loads(prog_file.read_text(encoding='utf-8'))
    except (json.JSONDecodeError, OSError):
        return {}

def _clear_progress(prog_file: Path):
    """Delete a progress file if it exists."""
    try:
        if prog_file.exists():
            prog_file.unlink()
    except OSError:
        pass

def _atomic_write(target: Path, content: str):
    """Write *content* to *target* via temp + rename for crash safety."""
    target.parent.mkdir(parents=True, exist_ok=True)
    tmp = target.parent / f".{target.name}.tmp"
    tmp.write_text(content, encoding='utf-8')
    os.replace(str(tmp), str(target))

def _resume_or_ask(progress: dict, prog_file: Path, key: str,
                   label: str, ask_fn, *args, **kwargs):
    """Return a saved answer from *progress*, or call *ask_fn* and persist it."""
    if key in progress:
        info(f"  [resumed] {label}: {progress[key]}")
        return progress[key]
    val = ask_fn(*args, **kwargs)
    progress[key] = val
    _save_progress(prog_file, progress)
    return val

# Legacy path helpers for backward compatibility
def _legacy_user_path() -> Path:
    """Old location for user.md (inside deft framework dir)."""
    return get_script_dir() / "core" / "user.md"

def _legacy_project_path() -> Path:
    """Old location for project.md (inside deft framework dir)."""
    return Path("./deft/core/project.md")

# Non-language support files to exclude from language selection
_NON_LANGUAGE_FILES = {'commands', 'markdown', 'mermaid'}

# Display name overrides for language file stems
_LANGUAGE_DISPLAY_NAMES = {
    'cpp': 'C++',
    'c#': 'C#',
    'c': 'C',
    'r': 'R',
    'sql': 'SQL',
    'vhdl': 'VHDL',
    'javascript': 'JavaScript',
    'typescript': 'TypeScript',
    'visual-basic': 'Visual Basic',
}

def get_available_languages() -> List[tuple]:
    """Scan languages/ directory and return available programming languages.
    
    Returns:
        Sorted list of (stem, display_name) tuples.
        Excludes non-language support files (commands, markdown, mermaid).
    """
    lang_dir = get_script_dir() / "languages"
    if not lang_dir.is_dir():
        return []
    
    languages = []
    for f in lang_dir.glob("*.md"):
        stem = f.stem
        if stem.lower() in _NON_LANGUAGE_FILES:
            continue
        display = _LANGUAGE_DISPLAY_NAMES.get(
            stem, _LANGUAGE_DISPLAY_NAMES.get(
            stem.lower(), stem.replace('-', ' ').title()))
        languages.append((stem, display))
    
    return sorted(languages, key=lambda x: x[1].lower())

def _lang_widget_id(stem: str) -> str:
    """Create a valid Textual widget ID from a language file stem."""
    return "lang_" + stem.replace('#', 'sharp').replace('+', 'plus')

# Non-strategy support files to exclude from strategy selection
# Includes aliases (brownfield, default) which are internal and should not appear in the picker
_NON_STRATEGY_FILES = {'readme', 'brownfield', 'default'}

# Display name overrides for strategy file stems
_STRATEGY_DISPLAY_NAMES = {
    'speckit': 'SpecKit',
}

# One-line descriptions shown in strategy picker
_STRATEGY_DESCRIPTIONS = {
    'interview': 'Structured interview with sizing gate — Light (embedded spec) or Full (PRD → spec)',
    'yolo':      'Auto-pilot interview — Johnbot picks all recommended options',
    'map':       'Analyze existing codebase conventions before adding features',
    'discuss':   'Front-load decisions and alignment before planning',
    'research':  'Investigate the domain before planning',
    'speckit':   'Five-phase spec-driven workflow for large/complex projects',
    # 'default' and 'brownfield' are aliases excluded via _NON_STRATEGY_FILES — no entries needed here
}

def get_available_strategies() -> List[tuple]:
    """Scan strategies/ directory and return available strategies.
    
    Returns:
        Sorted list of (stem, display_name) tuples.
        Excludes non-strategy support files (README).
    """
    strat_dir = get_script_dir() / "strategies"
    if not strat_dir.is_dir():
        return []
    
    strategies = []
    for f in strat_dir.glob("*.md"):
        stem = f.stem
        if stem.lower() in _NON_STRATEGY_FILES:
            continue
        display = _STRATEGY_DISPLAY_NAMES.get(
            stem, _STRATEGY_DISPLAY_NAMES.get(
            stem.lower(), stem.replace('-', ' ').title()))
        strategies.append((stem, display))
    
    return sorted(strategies, key=lambda x: x[1].lower())

def usage():
    """Print usage information"""
    hint = ""
    if not HAS_RICH:
        # Get the Python executable path for accurate install command
        python_exe = sys.executable
        stdlib_path = Path(sys.base_prefix) / "lib" / f"python{sys.version_info.major}.{sys.version_info.minor}"
        is_externally_managed = (stdlib_path / "EXTERNALLY-MANAGED").exists()
        
        install_cmd = f"{python_exe} -m pip install"
        if is_externally_managed:
            install_cmd += " --break-system-packages"
        install_cmd += " rich"
        
        hint = f"\n💡 Tip: Install rich for enhanced output and better UX:\n   {install_cmd}\n"
    
    tui_hint = ""
    if HAS_TEXTUAL:
        tui_hint = "       run                     # Launch TUI wizard (no args)\n       run tui                  # Launch TUI wizard\n       run wizard               # Launch TUI wizard\n       "
    
    if HAS_RICH:
        print_header(f"Deft CLI v{VERSION}")
        tui_section = "[bold]TUI Mode:[/bold]\n  run / run tui / run wizard    Launch interactive wizard\n\n" if HAS_TEXTUAL else ""
        console.print(f"""
{tui_section}[bold]Usage:[/bold] run <command> [options]
       run -h, --help, -help    # Show this help
       python run <command> [options]       # If not executable
       python3 run <command> [options]      # If not executable

[bold cyan]Commands:[/bold cyan]
  [green]bootstrap[/green]       Set up your user preferences (user.md)
  [green]project[/green]         Create/update project configuration (PROJECT-DEFINITION.vbrief.json)
  [green]spec[/green]            Generate scope vBRIEF in vbrief/proposed/ (--force to overwrite)
  [green]install[/green]         Install deft framework in a project directory
  [green]reset[/green]           Reset configuration files to default state
  [green]validate[/green]        Validate deft configuration files
  [green]update[/green]          Update deft framework to latest version
  [green]upgrade[/green]         Acknowledge framework upgrade; write .deft-version marker
  [green]doctor[/green]          Check system dependencies and configuration
  [green]help[/green]            Show this help message

[bold cyan]Examples:[/bold cyan]
  run                        # Launch TUI wizard (if textual installed)
  run bootstrap              # First-time setup
  run project                # Configure current project
  run spec                   # Generate scope vBRIEF
  run install ~/my-project   # Install deft in a project
  run reset                  # Reset config files (interactive)
  run reset --all            # Reset all config files (no prompts)
  run validate               # Check configuration is valid

For more information: [link]https://github.com/deftai/directive[/link]
""")
    else:
        tui_section = f"TUI Mode:\n{tui_hint}\n" if HAS_TEXTUAL else ""
        print(f"""Deft CLI v{VERSION}{hint}

{tui_section}Usage: run <command> [options]
       run -h, --help, -help    # Show this help
       python run <command> [options]       # If not executable
       python3 run <command> [options]      # If not executable

Commands:
  bootstrap       Set up your user preferences (user.md)
  project         Create/update project configuration (PROJECT-DEFINITION.vbrief.json)
  spec            Generate scope vBRIEF in vbrief/proposed/ (--force to overwrite)
  install         Install deft framework in a project directory
  reset           Reset configuration files to default state
  validate        Validate deft configuration files
  update          Update deft framework to latest version
  upgrade         Acknowledge framework upgrade; write .deft-version marker
  doctor          Check system dependencies and configuration
  help            Show this help message

Examples:
  run                        # Launch TUI wizard (if textual installed)
  run bootstrap              # First-time setup
  run project                # Configure current project
  run spec                   # Generate scope vBRIEF
  run install ~/my-project   # Install deft in a project
  run reset                  # Reset config files (interactive)
  run reset --all            # Reset all config files (no prompts)
  run validate               # Check configuration is valid

For more information: https://github.com/deftai/directive
""")

def ask_input(prompt_text: str, default: str = "") -> str:
    """Read user input with optional default
    
    Args:
        prompt_text: The prompt to display
        default: Default value if user presses Enter
    
    Returns:
        User input or default value
    """
    try:
        # Priority: prompt_toolkit (best editing) > rich > basic input
        if HAS_PROMPT_TOOLKIT:
            from prompt_toolkit import prompt as pt_prompt
            from prompt_toolkit.formatted_text import HTML
            # Add colored prefix if rich is also available
            if HAS_RICH:
                display_prompt = HTML(f'<ansibrightcyan>?</ansibrightcyan> {prompt_text}: ')
            else:
                display_prompt = prompt_text + ": "
            
            value = pt_prompt(display_prompt, default=default)
            return value if value else default
        elif HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            value = Prompt.ask(formatted_prompt, default=default if default else None)
            return value if value else default
        else:
            # Fall back to basic input() with readline support (if available on Unix)
            if default:
                value = input(f"{prompt_text} [{default}]: ")
            else:
                value = input(f"{prompt_text}: ")
            return value if value else default
    except EOFError:
        return default

def ask_choice(prompt_text: str, choices: List[str], default: str = None) -> str:
    """Read user choice from list
    
    Args:
        prompt_text: The prompt to display
        choices: List of valid choices
        default: Default choice
    
    Returns:
        User's choice
    """
    try:
        if HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            return Prompt.ask(formatted_prompt, choices=choices, default=default)
        else:
            # Fallback: show numbered list
            print(f"\n{prompt_text}")
            for i, choice in enumerate(choices, 1):
                print(f"  {i}. {choice}")
            while True:
                ans = input("Enter number: ")
                try:
                    idx = int(ans) - 1
                    if 0 <= idx < len(choices):
                        return choices[idx]
                except ValueError:
                    pass
                print("Invalid choice, try again.")
    except EOFError:
        return default if default else choices[0]

def ask_confirm(prompt_text: str, default: bool = False) -> bool:
    """Read yes/no confirmation
    
    Args:
        prompt_text: The prompt to display
        default: Default value
    
    Returns:
        True if user confirms, False otherwise
    """
    try:
        # Priority: prompt_toolkit > rich > basic input
        if HAS_PROMPT_TOOLKIT:
            from prompt_toolkit import prompt as pt_prompt
            from prompt_toolkit.formatted_text import HTML
            # Add colored prefix if rich is also available
            suffix = " (Y/n): " if default else " (y/N): "
            if HAS_RICH:
                display_prompt = HTML(f'<ansibrightcyan>?</ansibrightcyan> {prompt_text}{suffix}')
            else:
                display_prompt = prompt_text + suffix
            
            response = pt_prompt(display_prompt, default="")
            if not response:
                return default
            return response.strip().lower() in ('y', 'yes')
        elif HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            return Confirm.ask(formatted_prompt, default=default)
        else:
            suffix = " (Y/n) " if default else " (y/N) "
            response = input(f"{prompt_text}{suffix}")
            if not response:
                return default
            return response.strip().lower() in ('y', 'yes')
    except EOFError:
        return default

# Legacy aliases
read_input = ask_input
read_yn = ask_confirm

# --- Upgrade gate (#410) ---------------------------------------------------
#
# `.deft/core/run` is the one deterministic entry point directive controls that runs
# in the consumer project's working directory.  After a framework update, we
# compare a `.deft-version` marker to VERSION and warn on drift.  Non-fatal by
# design: interactive sessions get a prompt ("continue anyway? [y/N]"),
# non-interactive sessions warn once and continue so CI/cloud runs are not
# blocked.  See issue #410 for scope boundaries (CLI users only; the
# agent-interpreted path is gated by the sync/setup skills).

def _version_marker_paths(project_root: Path) -> List[Path]:
    """Return candidate `.deft-version` paths, preferred location first."""
    return [project_root / "vbrief" / ".deft-version", project_root / ".deft-version"]


def _read_version_marker(project_root: Path) -> Optional[str]:
    """Return the recorded framework version, or None if no marker exists.

    Iterates candidate paths in preference order; an OSError on the preferred
    path (e.g. unreadable due to permissions) falls through to the fallback
    so version-drift detection is not silently suppressed (#410).
    """
    for candidate in _version_marker_paths(project_root):
        if candidate.is_file():
            try:
                return candidate.read_text(encoding="utf-8").strip()
            except OSError:
                continue
    return None


def _write_version_marker(vbrief_root: Path) -> None:
    """Write VERSION into `vbrief/.deft-version` (best-effort, never raises).

    #1454: refuses to persist the ``0.0.0-dev`` dev-checkout sentinel into a
    consumer marker -- writing it would clobber a real recorded version on a
    dev checkout (or a vendored install whose git context could not be
    trusted). The prior marker value, if any, is preserved. It remains fine
    for ``_resolve_version`` to RETURN the sentinel in-process; the rule is
    only about not WRITING it.
    """
    if VERSION == _DEV_VERSION_SENTINEL:
        return
    try:
        vbrief_root.mkdir(parents=True, exist_ok=True)
        (vbrief_root / ".deft-version").write_text(VERSION + "\n", encoding="utf-8")
    except OSError:
        pass


def _detect_pre_cutover_legacy(project_root: Path) -> List[str]:
    """Return legacy pre-v0.20 root artifacts using the shared detector."""
    scripts_dir = Path(__file__).resolve().parent / "scripts"
    if str(scripts_dir) not in sys.path:
        sys.path.insert(0, str(scripts_dir))
    from _precutover import detect_pre_cutover_legacy  # type: ignore[import-not-found]

    return detect_pre_cutover_legacy(project_root)


# Positive framework-repo markers used by `_running_inside_deft_repo` to
# distinguish the deft source checkout from a consumer project that happens
# to carry a root-level `main.md` for unrelated reasons. Both must resolve
# under `project_root` for the heuristic to fire as "yes, this is the deft
# framework repo itself" -- a consumer mirroring even one of these paths is
# vanishingly unlikely (each is purely framework-internal), and requiring
# BOTH defends against accidental drift if a future consumer convention
# starts colliding with a single name. See #1303 review (SLizard P1 +
# Greptile carryover).
_DEFT_REPO_POSITIVE_MARKERS = (
    Path("templates") / "agents-entry.md",
    Path("skills") / "deft-directive-build" / "SKILL.md",
)


def _running_inside_deft_repo(project_root: Path) -> bool:
    """Heuristic: True when `run` is invoked from inside the deft repo itself.

    Consumer projects embed deft as ``./deft/`` (legacy) or ``./.deft/core/``
    (canonical) and consume the framework's published surface; the deft
    source repo carries ``main.md`` at its root, has neither install
    location materialised inside its own checkout, AND ships a set of
    framework-internal artefacts (notably ``templates/agents-entry.md`` and
    ``skills/deft-directive-build/SKILL.md``) a consumer would have no
    reason to mirror.

    The heuristic fires only when ALL of the following hold:
      * ``main.md`` is present at ``project_root`` (the documented entry
        point a consumer never reproduces verbatim).
      * NEITHER ``./deft`` (legacy install) NOR ``./.deft/core`` (canonical
        install) exists at the project root -- both indicate the deft
        framework was installed INTO this directory rather than that this
        directory IS the framework.
      * ALL of the markers in ``_DEFT_REPO_POSITIVE_MARKERS`` resolve --
        framework-internal paths a consumer would never reproduce.

    The original heuristic (#1272 baseline) checked only ``main.md`` plus
    the absence of ``./deft``; that mis-fired on a consumer who happened
    to carry a root-level ``main.md`` for unrelated reasons OR who
    installed canonically to ``./.deft/core`` and so genuinely had no
    ``./deft`` subdirectory -- doctor would then silently skip the
    Taskfile-include diagnostic in exactly the place it was meant to
    surface (#1303 review SLizard P1, Greptile carryover).

    Skipping the gate here avoids nagging deft maintainers on every
    ``run`` invocation against the framework checkout itself.
    """
    if not (project_root / "main.md").is_file():
        return False
    if (project_root / "deft").is_dir():
        return False
    if (project_root / ".deft" / "core").is_dir():
        return False
    for marker in _DEFT_REPO_POSITIVE_MARKERS:
        if not (project_root / marker).is_file():
            return False
    return True


# Commands for which the gate is silent -- they never touch project state.
_UPGRADE_GATE_SKIP_COMMANDS = frozenset({
    "help", "--help", "-h", "-help",
    "version", "--version", "-v",
    "upgrade",  # the upgrade command itself must run so users can resolve the gate
    # #768: cmd_gate IS the upgrade gate -- if the agent invokes it from the
    # AGENTS.md preamble, it must not recursively re-trigger the legacy CLI
    # gate prompt. cmd_agents_refresh likewise must run unconditionally so the
    # universal preamble's recovery path can call it.
    "gate",
    "agents:refresh",
    # #801: cmd_check_updates is the probe surface the upgrade gate calls
    # internally; invoking it from the CLI must not recursively re-trigger
    # the gate (which would itself call the probe).
    "check-updates",
    # #1272 / #1303 review: ``run doctor`` (and the ``task doctor`` shim that
    # wraps it) is the canonical surface operators reach for when the gate
    # itself is misbehaving. It MUST run without invoking the upgrade-gate
    # prompt because:
    #   (a) ``--session`` advertises a "NEVER prompts" contract for
    #       session-start rituals, and the gate's interactive prompt would
    #       violate that promise.
    #   (b) Operators in a drift state would be unable to diagnose the
    #       drift if the gate refused them entry to the diagnostic.
    # The gate's drift advisories surface during the routine commands that
    # actually mutate project state (install / project / spec / migrate);
    # the doctor surface is read-only by default and never warrants the
    # gate prompt.
    "doctor",
})


def _emit_event_safe(name: str, payload: dict) -> None:
    """Lazy-import emit() and swallow all failures.

    Keeps the events surface optional from `run`'s perspective:
    `scripts/_event_detect.py` is imported only when actually emitting, and
    any ImportError / OSError / EventEmissionError is silently dropped so
    the CLI never breaks because of an event-surface bug. Per #635.
    """
    # Bare ``except Exception`` swallows every failure mode the events
    # surface could surface (ImportError when the helper file is missing,
    # OSError when DEFT_EVENT_LOG points at a read-only path,
    # EventEmissionError when the registry rejects the name) without
    # leaking any of them up to the CLI.
    try:
        scripts_dir = get_script_dir() / "scripts"
        if str(scripts_dir) not in sys.path:
            sys.path.insert(0, str(scripts_dir))
        # #635: detection-bound emit helper (distinct from behavioral sibling).
        from _event_detect import emit  # type: ignore[import-not-found]
        emit(name, payload)
    except Exception:  # noqa: BLE001 -- non-fatal; events MUST NOT break CLI
        return


# --- Periodic remote-version probe (#801) ---------------------------------
#
# A read-only `git ls-remote --tags --refs <upstream>` probe lets the upgrade
# gate surface upstream releases the consumer has not yet pulled. The probe is
# opt-out (DEFT_NO_NETWORK=1), throttled (24h between probes / 24h between
# notifications, per-tag re-notification on a fresh release), and never
# auto-mutates project state -- write paths still flow through cmd_upgrade,
# the sync skill, or `task migrate:vbrief`.  Implementation lives below the
# event helpers so it can use _emit_event_safe; it is intentionally placed
# above _check_upgrade_gate so the gate can call _maybe_emit_remote_drift_warning.

# Module-level dedup: at most one probe-driven banner per `run` invocation
# chain so chained commands (e.g. cmd_install -> cmd_project -> cmd_spec) do
# not stack three identical warn lines.
_PROBE_NOTIFIED_THIS_SESSION = False

# Filename for the throttle file under vbrief/.
_REMOTE_PROBE_STATE_FILENAME = ".deft-remote-probe.json"

# Default cadence floors. Both probe and notification respect a 24h floor so
# six minor releases in eight days do not produce six banners; per-tag
# re-notification is handled separately so a fresh release re-notifies even
# if the prior tag was just dismissed.
_REMOTE_PROBE_CADENCE_HOURS = 24
_REMOTE_NOTIFY_CADENCE_HOURS = 24

# Default subprocess timeout for `git ls-remote` -- intentionally tight so
# offline consumers do not hang on the gate. Override via
# DEFT_REMOTE_PROBE_TIMEOUT env var (float seconds; non-positive falls back).
_REMOTE_PROBE_DEFAULT_TIMEOUT = 5.0

# Baked-in canonical upstream for the directive framework (#1320). The
# remote-version probe resolves the upstream from the install manifest's
# ``url`` field first, then falls back to this constant -- and NEVER to the
# consumer's ``origin`` remote. On a vendored ``.deft/core/`` install (no
# nested ``.git``) the consumer's origin is the ONLY git context, so probing
# it would mistake the consumer's repo for the framework upstream.
DEFT_UPSTREAM_URL = "https://github.com/deftai/directive.git"

# Manifest fields that may carry the framework upstream URL (a ``source.url``
# equivalent). The flat ``key: value`` manifest parser lower-cases keys and
# cannot represent dotted YAML paths, so we accept a small set of flat
# spellings any writer rail (Go installer / oz-agent-upgrade) might emit.
_MANIFEST_UPSTREAM_URL_KEYS = ("source_url", "url", "upstream_url", "upstream", "origin")


def _remote_probe_state_path(project_root: Path) -> Path:
    """Return the throttle file path for the given project root."""
    return project_root / "vbrief" / _REMOTE_PROBE_STATE_FILENAME


def _read_remote_probe_state(project_root: Path) -> dict:
    """Best-effort read of the throttle file. Returns ``{}`` on any failure.

    Failures (missing file, malformed JSON, OSError on read-only filesystems)
    silently degrade to an empty state so detection never blocks the gate.
    """
    path = _remote_probe_state_path(project_root)
    if not path.is_file():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return {}
    return data if isinstance(data, dict) else {}


def _write_remote_probe_state(project_root: Path, state: dict) -> None:
    """Best-effort write of the throttle file (never raises).

    Mirrors ``_write_version_marker`` so a read-only filesystem (CI cache,
    container layer) silently degrades rather than crashing the gate.
    """
    path = _remote_probe_state_path(project_root)
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps(state, sort_keys=True, indent=2) + "\n",
            encoding="utf-8",
        )
    except OSError:
        pass


def _now_utc() -> datetime:
    """Return UTC-aware ``datetime.now`` (split out for test monkeypatching)."""
    return datetime.now(timezone.utc)


def _now_utc_iso() -> str:
    """UTC ISO-8601 timestamp at seconds precision."""
    return _now_utc().strftime("%Y-%m-%dT%H:%M:%SZ")


def _parse_iso_utc(ts: str) -> Optional[datetime]:
    """Parse an ISO-8601 timestamp emitted by ``_now_utc_iso``.

    Accepts trailing ``Z`` and offsets; returns None on malformed input so
    callers treat a corrupt throttle file as "never probed".
    """
    if not ts:
        return None
    candidate = ts.strip()
    if candidate.endswith("Z"):
        candidate = candidate[:-1] + "+00:00"
    try:
        parsed = datetime.fromisoformat(candidate)
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=timezone.utc)
    return parsed.astimezone(timezone.utc)


_SEMVER_TAG_RE = re.compile(
    r"^v?(?P<major>\d+)\.(?P<minor>\d+)\.(?P<patch>\d+)"
    r"(?P<pre>-[\w][\w.-]*)?$"
)


def _parse_semver_tag(tag: str) -> Optional[tuple]:
    """Parse a tag like ``v1.2.3`` or ``v1.2.3-rc.1`` into a comparison key.

    Returns ``(major, minor, patch, is_release, prerelease_str)``. Stable
    releases sort above prereleases of the same triple via the
    ``is_release`` axis (``1`` > ``0``). Returns None for malformed input so
    the caller can skip and continue.
    """
    if not tag:
        return None
    match = _SEMVER_TAG_RE.match(tag.strip())
    if not match:
        return None
    pre = match.group("pre") or ""
    return (
        int(match.group("major")),
        int(match.group("minor")),
        int(match.group("patch")),
        0 if pre else 1,
        pre.lstrip("-"),
    )


def _max_semver_tag(tags: List[str]) -> Optional[str]:
    """Return the highest semver tag in ``tags``, or None if no tag parses.

    Malformed tags are skipped (not raised) so a single junk ref name on the
    upstream does not break the probe.
    """
    parsed: list = []
    for tag in tags:
        key = _parse_semver_tag(tag)
        if key is not None:
            parsed.append((key, tag))
    if not parsed:
        return None
    parsed.sort(key=lambda item: item[0])
    return parsed[-1][1]


def _read_vendored_manifest(project_root: Path) -> Optional[dict]:
    """Read the install manifest canonical-first for probe/version resolution (#1320).

    A vendored install deposits the framework at ``.deft/core`` (or legacy
    ``deft``) with no nested ``.git``; the only canonical version / upstream
    metadata lives in ``<install>/VERSION``. Probes the canonical location
    first, then the webinstaller-vendored ``.deft/VERSION``, then the legacy
    ``deft/VERSION``. Returns the parsed dict, or None when no manifest
    exists. Best-effort -- never raises.
    """
    for candidate in (
        project_root / ".deft" / "core" / "VERSION",
        project_root / ".deft" / "VERSION",
        project_root / "deft" / "VERSION",
    ):
        if candidate.is_file():
            try:
                text = candidate.read_text(encoding="utf-8")
            except OSError:
                continue
            return _parse_install_manifest(text)
    return None


def _resolve_probe_current_version(project_root: Path) -> str:
    """Resolve the version the probe should treat as ``current`` (#1320).

    On a vendored install the in-process ``VERSION`` may resolve to
    ``0.0.0-dev`` (no nested ``.git``); the install manifest's ``tag`` /
    ``ref`` is the authoritative installed version. Prefer it, falling back
    to the in-process ``VERSION`` when no manifest is present.
    """
    manifest = _read_vendored_manifest(project_root)
    if manifest:
        derived = _install_manifest_tag_to_version(manifest)
        if derived:
            return derived
    return VERSION


def _resolve_upstream_url(
    project_root: Path,
    *,
    timeout: Optional[float] = None,
) -> Optional[str]:
    """Resolve the directive framework's upstream remote URL (#1320).

    Resolution priority:
        1. The ``url`` (``source.url`` equivalent) field of the
           ``<install>/VERSION`` manifest, when present.
        2. The baked-in framework constant ``DEFT_UPSTREAM_URL``.

    The consumer's ``origin`` remote is NEVER consulted: on a vendored
    ``.deft/core/`` install (no nested ``.git``) the only git context is the
    CONSUMER's repo, so probing ``git remote get-url origin`` would mistake
    the consumer's origin for the framework upstream (#1320). ``timeout`` is
    retained for call-site compatibility but is unused now that resolution
    is filesystem + constant only (no subprocess).
    """
    del timeout  # no subprocess: resolution is manifest field + baked-in constant
    manifest = _read_vendored_manifest(project_root)
    if manifest:
        for key in _MANIFEST_UPSTREAM_URL_KEYS:
            value = manifest.get(key)
            if isinstance(value, str) and value.strip():
                return value.strip()
    return DEFT_UPSTREAM_URL


def _ls_remote_tags(upstream_url: str, timeout: float) -> List[str]:
    """Run ``git ls-remote --tags --refs <upstream>`` and return tag names.

    Raises ``subprocess.TimeoutExpired`` or ``OSError`` (FileNotFoundError
    when ``git`` is absent) so the caller can categorise the failure mode
    in its return shape.
    """
    result = subprocess.run(
        ["git", "ls-remote", "--tags", "--refs", upstream_url],
        capture_output=True,
        text=True,
        timeout=timeout,
        check=False,
    )
    if result.returncode != 0:
        return []
    tags: List[str] = []
    for line in (result.stdout or "").splitlines():
        # Expected line shape: "<sha>\trefs/tags/<tag>"
        if "\trefs/tags/" not in line:
            continue
        tag = line.split("\trefs/tags/", 1)[1].strip()
        if tag:
            tags.append(tag)
    return tags


def _resolve_probe_timeout() -> float:
    """Return the subprocess timeout for the probe (env-overridable)."""
    raw = os.environ.get("DEFT_REMOTE_PROBE_TIMEOUT", "").strip()
    if not raw:
        return _REMOTE_PROBE_DEFAULT_TIMEOUT
    try:
        value = float(raw)
    except ValueError:
        return _REMOTE_PROBE_DEFAULT_TIMEOUT
    return value if value > 0 else _REMOTE_PROBE_DEFAULT_TIMEOUT


def _no_network_active() -> bool:
    """Return True when DEFT_NO_NETWORK=1 (silent skip semantics)."""
    return os.environ.get("DEFT_NO_NETWORK", "").strip() == "1"


def _force_remote_probe_active() -> bool:
    """Return True when DEFT_FORCE_REMOTE_PROBE=1 (bypass throttle)."""
    return os.environ.get("DEFT_FORCE_REMOTE_PROBE", "").strip() == "1"


def _run_remote_probe(project_root: Path) -> dict:
    """Internal probe -- returns a structured status dict; never prints.

    Status values:
        ``ok``          -- upstream resolved, remote tag <= current VERSION
        ``behind``      -- upstream resolved, remote tag > current VERSION
        ``skipped``     -- DEFT_NO_NETWORK=1 short-circuit
        ``no-upstream`` -- could not resolve an upstream remote
        ``no-tags``     -- upstream resolved but produced no semver tags
        ``error``       -- subprocess timeout / git missing / other I/O
    """
    # #1320: resolve ``current`` from the install manifest (ref/tag) before
    # the in-process VERSION so a vendored install (no nested .git) reports
    # its installed version rather than the 0.0.0-dev fallback.
    current = _resolve_probe_current_version(project_root)
    if _no_network_active():
        return {
            "status": "skipped",
            "reason": "DEFT_NO_NETWORK=1",
            "current": current,
        }
    timeout = _resolve_probe_timeout()
    upstream_url = _resolve_upstream_url(project_root, timeout=timeout)
    if not upstream_url:
        return {"status": "no-upstream", "current": current}
    try:
        tags = _ls_remote_tags(upstream_url, timeout)
    except subprocess.TimeoutExpired:
        return {
            "status": "error",
            "current": current,
            "upstream_url": upstream_url,
            "error": "timeout",
        }
    except OSError as exc:
        return {
            "status": "error",
            "current": current,
            "upstream_url": upstream_url,
            "error": f"{type(exc).__name__}: {exc}",
        }
    remote_tag = _max_semver_tag(tags)
    if remote_tag is None:
        return {
            "status": "no-tags",
            "current": current,
            "upstream_url": upstream_url,
        }
    remote_key = _parse_semver_tag(remote_tag)
    current_key = _parse_semver_tag(current)
    if (
        current_key is not None
        and remote_key is not None
        and remote_key > current_key
    ):
        return {
            "status": "behind",
            "current": current,
            "remote": remote_tag,
            "upstream_url": upstream_url,
        }
    return {
        "status": "ok",
        "current": current,
        "remote": remote_tag,
        "upstream_url": upstream_url,
    }


def _maybe_emit_remote_drift_warning(project_root: Path) -> None:
    """Throttled probe + warn-line emission for the upgrade gate (#801).

    Best-effort: every failure mode is swallowed so the gate never breaks
    because of the probe. Emits one informational warn line on positive
    BEHIND, one ``framework:remote-drift`` event, and updates the throttle
    file in ``vbrief/.deft-remote-probe.json``. Throttle keys (24h probe /
    24h notification, per-tag re-notification) are honored; per-session
    dedup is enforced via ``_PROBE_NOTIFIED_THIS_SESSION``.
    """
    global _PROBE_NOTIFIED_THIS_SESSION
    try:
        if _PROBE_NOTIFIED_THIS_SESSION:
            return
        force = _force_remote_probe_active()
        state = _read_remote_probe_state(project_root)
        now = _now_utc()
        last_probed = _parse_iso_utc(state.get("last_probed_at", ""))
        probe_floor = timedelta(hours=_REMOTE_PROBE_CADENCE_HOURS)
        if (
            not force
            and last_probed is not None
            and (now - last_probed) < probe_floor
        ):
            return  # too soon to probe again

        result = _run_remote_probe(project_root)
        new_state = dict(state)
        new_state["last_probed_at"] = _now_utc_iso()
        if result.get("status") == "behind":
            new_state["last_seen_remote"] = result["remote"]
        # Persist the probe timestamp regardless of outcome so the cadence
        # also throttles ``no-upstream`` / ``error`` paths -- otherwise a
        # detached HEAD probe would re-shell `git ls-remote` on every
        # gate invocation.
        _write_remote_probe_state(project_root, new_state)

        if result.get("status") != "behind":
            return

        remote_tag = result["remote"]
        last_notified_tag = state.get("last_notified_tag", "")
        last_notified_at = _parse_iso_utc(state.get("last_notified_at", ""))
        notify_floor = timedelta(hours=_REMOTE_NOTIFY_CADENCE_HOURS)
        same_tag_within_floor = (
            last_notified_tag == remote_tag
            and last_notified_at is not None
            and (now - last_notified_at) < notify_floor
        )
        if not force and same_tag_within_floor:
            return

        warn(
            f"Upstream directive {remote_tag} is available "
            f"(you are on v{VERSION}). Run "
            "`task framework:check-updates` for details; follow "
            "`skills/deft-directive-sync/SKILL.md` Phase 2 to update."
        )
        _emit_event_safe(
            "framework:remote-drift",
            {
                "project_root": str(project_root.resolve()),
                "current_version": VERSION,
                "remote_version": remote_tag,
                "upstream_url": result.get("upstream_url", ""),
                "commits_behind": None,
            },
        )
        new_state["last_notified_at"] = _now_utc_iso()
        new_state["last_notified_tag"] = remote_tag
        _write_remote_probe_state(project_root, new_state)
        _PROBE_NOTIFIED_THIS_SESSION = True
    except Exception:  # noqa: BLE001 -- detection MUST NOT break the gate
        return


# --- #1046 PR-B: framework:doctor + session-boundary hooks -----------------
#
# Both hooks are best-effort -- their failure modes are swallowed so the
# upgrade gate never breaks because of the doctor probe (mirrors the
# #801 remote-version probe contract). The doctor hook fires AFTER the
# install-layout prompt so its diagnostics layer on top of the existing
# detection signal (Case K + B/C/D states still surface first).

# _DOCTOR_NOTIFIED_THIS_SESSION retired per #1336 (legacy framework doctor path removed).
_SAME_SESSION_REFRESH_WARNED = False


def _maybe_warn_same_session_refresh(project_root: Path) -> None:
    """Warn when AGENTS.md was refreshed within the current session lineage (#1046 PR-B AC-5).

    Implements the Finding #6 enforcement: when ``DEFT_SESSION_ID`` is
    set AND equals the embedded ``session=`` token on the managed-section
    marker, the gate emits a one-line warn telling the operator to start
    a new session instead of silently letting Case G re-run with stale
    in-memory context. Best-effort -- silently degrades on any read /
    parse failure so the gate never breaks because of the hook.

    No-op (no warn line, no side effect) when:
      * ``DEFT_SESSION_ID`` is unset (no way to detect lineage).
      * AGENTS.md is absent or has no v3 marker.
      * Embedded session id differs from the current ``DEFT_SESSION_ID``.
      * The hook has already fired this run (``_SAME_SESSION_REFRESH_WARNED``
        is set).
    """
    global _SAME_SESSION_REFRESH_WARNED
    if _SAME_SESSION_REFRESH_WARNED:
        return
    try:
        current_session = os.environ.get(_ENV_SESSION_ID, "").strip()
        if not current_session:
            return
        agents_md = project_root / "AGENTS.md"
        if not agents_md.is_file():
            return
        text = agents_md.read_text(encoding="utf-8", errors="replace")
        extracted = _extract_managed_section(text)
        if extracted is None:
            return
        attrs = _parse_managed_section_attrs(extracted)
        if attrs is None or attrs["version"] < 3:
            return
        embedded_session = (attrs.get("session") or "").strip()
        if not embedded_session or embedded_session != current_session:
            return
        refreshed = (attrs.get("refreshed") or "").strip()
        sha_hint = (attrs.get("sha") or "unknown").strip()
        warn(
            "AGENTS.md managed section was refreshed in THIS session "
            f"(session={embedded_session}, refreshed={refreshed}, sha={sha_hint}). "
            "Start a NEW agent session before re-running the refresh -- "
            "the current context still holds the pre-refresh AGENTS.md "
            "and re-running Case G would be a documented no-op. "
            "Refs #1046 finding #6."
        )
        _SAME_SESSION_REFRESH_WARNED = True
    except Exception:  # noqa: BLE001 -- detection MUST NOT break the gate
        return


# _maybe_run_framework_doctor retired per #1336 (Epic-2).
# The legacy framework:doctor advisory hook and its import of
# scripts/framework_doctor.py have been removed from production paths
# (upgrade gate + run doctor integration). scripts/doctor.py is now the
# single owner. The global _DOCTOR_NOTIFIED_THIS_SESSION and related
# throttle for the old path are also retired (canonical doctor throttle
# lives in scripts/_doctor_state.py + scripts/doctor.py).
# See vbrief/active/2026-05-29-1336-*.vbrief.json .


def _check_upgrade_gate(command: str) -> bool:
    """Warn (and prompt when interactive) on framework/project version drift.

    Returns True if the caller should proceed, False only when the user
    explicitly declines in an interactive session.  Never fatal otherwise --
    in non-interactive environments (CI, cloud agents) we warn and continue.

    Output ordering on the unhappy path (drift / legacy):
        1. version:drift OR pre-cutover:detected event + warn line (#410, #635)
        2. agents-md:stale event (silent, structural only) (#635, #768)
        3. framework:remote-drift event + warn line on positive BEHIND (#801)
        4. interactive prompt OR non-interactive pass-through

    Output ordering on the happy path (marker matches VERSION, or no
    marker + no legacy artifacts):
        1. agents-md:stale event (silent)
        2. framework:remote-drift event + warn line on positive BEHIND (#801)
           -- the probe is the only signal a current-marker consumer has
           that an upstream release is available, so it MUST run on the
           happy path. Throttled (24h cadence + per-tag re-notification +
           per-session dedup) so the cost of running it always is bounded.
        3. framework:doctor advisory + warn line on positive DRIFT (#1046 PR-B)
           -- the doctor is the only signal for layout-mismatch /
           manifest-drift / skill-path resolution failures that the
           remote probe does not cover. Informational only.
        4. same-session-refresh warn line on DEFT_SESSION_ID match
           (#1046 PR-B AC-5; finding #6) -- detects Case G no-op re-entry
           inside the same agent session and escalates instead of silently
           letting the refresh re-run.
    """
    if command in _UPGRADE_GATE_SKIP_COMMANDS:
        return True

    project_root = Path.cwd()
    if _running_inside_deft_repo(project_root):
        return True

    recorded = _read_version_marker(project_root)
    needs_prompt = False  # #410: True iff the gate has surfaced an actionable
    # local-drift signal (recorded-vs-current OR pre-cutover artifacts) that
    # warrants a `Continue anyway?` prompt in interactive sessions. The
    # remote-drift probe (#801) is informational only and never sets this
    # flag -- a fresh upstream release should not block the consumer's CI.

    if recorded is not None:
        if recorded != VERSION:
            # #635: emit version:drift before warning so consumers can react
            # uniformly. Marker path resolution mirrors _read_version_marker's
            # precedence rule (vbrief/.deft-version > .deft-version).
            marker_path = next(
                (str(p) for p in _version_marker_paths(project_root) if p.is_file()),
                "",
            )
            _emit_event_safe(
                "version:drift",
                {
                    "project_root": str(project_root.resolve()),
                    "recorded_version": recorded,
                    "current_version": VERSION,
                    "marker_path": marker_path,
                },
            )
            warn(
                f"Deft has been updated from {recorded} to {VERSION}. "
                "Run `.deft/core/run upgrade` or `task migrate:vbrief` to update your project files."
            )
            needs_prompt = True
    else:
        legacy = _detect_pre_cutover_legacy(project_root)
        if legacy:
            # #635: emit pre-cutover:detected before warning so consumers can
            # react uniformly (skill, task, CI runner). Existing CLI warning
            # text is preserved verbatim below.
            _emit_event_safe(
                "pre-cutover:detected",
                {
                    "project_root": str(project_root.resolve()),
                    "legacy_files": list(legacy),
                },
            )
            # Legacy artifacts present (with or without vbrief/) -- this
            # covers both the canonical v0.19 consumer layout (no vbrief/
            # yet) and a partially-migrated project that still has legacy
            # copies.
            warn(
                "Pre-v0.20 document model detected ("
                + ", ".join(legacy)
                + "). Run `task migrate:vbrief` to upgrade."
            )
            needs_prompt = True

    # #635: AGENTS.md staleness is checked alongside version drift /
    # pre-cutover so the upgrade gate emits a single coherent set of events
    # for consumers that subscribe via DEFT_EVENT_LOG. No new CLI output --
    # the existing QUICK-START.md prose flow is the user-visible surface;
    # the event is purely structural.
    try:
        scripts_dir = get_script_dir() / "scripts"
        if str(scripts_dir) not in sys.path:
            sys.path.insert(0, str(scripts_dir))
        from _event_detect import detect_agents_md_stale  # type: ignore[import-not-found]
        stale_payload = detect_agents_md_stale(project_root)
        if stale_payload is not None:
            _emit_event_safe("agents-md:stale", stale_payload)
    except Exception:
        # Detection MUST NOT break the gate.
        pass

    # #801: periodic remote-version probe. The helper is best-effort and
    # already swallows every failure mode internally; the outer try/except
    # is belt-and-suspenders so even a future bug in the helper signature
    # cannot break the gate.
    try:
        _maybe_emit_remote_drift_warning(project_root)
    except Exception:
        pass

    # #992 PR3: install-layout state detector + auto-prompt. Fires on
    # non-A states (B / C / D) regardless of version-marker drift -- the
    # prompt is informational only and does NOT set ``needs_prompt`` so
    # the existing ``Continue anyway?`` blocking prompt path is not
    # triggered solely because the install layout has drifted. Operator
    # consent is required to act (mirrors the #884 ghx-install consent
    # gate convention). Read-only -- the detector NEVER mutates state.
    try:
        _maybe_emit_install_layout_prompt(project_root)
    except Exception:  # noqa: BLE001 -- detection MUST NOT break the gate
        pass

    # #1336 (Epic-2): legacy framework:doctor hook retired.
    # The _maybe_run_framework_doctor path (and its import of
    # scripts/framework_doctor.py) has been removed from the upgrade gate.
    # Install integrity is now surfaced exclusively through the canonical
    # scripts/doctor.py surface (and task doctor / run doctor).
    # See vbrief/active/*1336*.vbrief.json and scripts/doctor.py header.

    # #1046 PR-B AC-5: same-session refresh detection. Fires when
    # DEFT_SESSION_ID is set AND matches the embedded session token on
    # the v3 marker -- the Finding #6 escalation that prevents Case G
    # from silently re-running in the same agent session. Informational
    # only; never sets ``needs_prompt`` (the warn line is the
    # actionable surface).
    try:
        _maybe_warn_same_session_refresh(project_root)
    except Exception:  # noqa: BLE001 -- detection MUST NOT break the gate
        pass

    # On the happy path (no local drift, no legacy artifacts), there is no
    # actionable prompt to surface even if the remote probe emitted a banner
    # -- remote drift is informational, not blocking.
    if not needs_prompt:
        return True

    # Non-interactive: warn and continue, never fatal.
    if not sys.stdin.isatty():
        return True

    try:
        if read_yn("Continue anyway?", default=False):
            return True
    except (EOFError, KeyboardInterrupt):
        return True

    warn("Exiting -- upgrade your project and re-run.")
    return False


# --- Universal upgrade gate (#768) -----------------------------------------
#
# `cmd_gate` is a read-only state-vector probe that any AGENTS.md / SKILL.md
# preamble (`<!-- DEFT-PREAMBLE-V1 -->`) can call before doing anything else.
# Output is one line on stdout in two shapes:
#
#   OK v<current>
#   NEEDS-UPGRADE recorded=<recorded|unknown> current=<current> precutover=<csv|empty> agents-md=<current|stale|missing|absent>
#
# `--json` emits the same axes as a single JSON object on stdout. Exit code is
# 0 for OK and 1 for NEEDS-UPGRADE. The probe never writes any markers, never
# triggers any migration, and never commits anything: the agent reads the
# state vector, then reads `deft/UPGRADING.md` for the matching section.
#
# `cmd_agents_refresh` is the Python reference implementation of the
# AGENTS.md contract surfaced by `templates/agents-entry.md`. It handles four
# states (`current`, `stale`, `missing`, `absent`) and exposes `--check` and
# `--dry-run` so the gate (and tests) can interrogate it without writing.
#
# Both functions are intentionally side-effect-free apart from `print()` so
# the test harness can capture stdout via the `run_command` fixture.

# --- Shared AGENTS.md managed-section helpers (scripts/_agents_md.py, #1389) ---
#
# The managed-section parse / render / refresh-plan helpers were extracted to
# the pure, side-effect-free module ``scripts/_agents_md.py`` so BOTH this CLI
# and ``scripts/doctor.py`` import ONE implementation instead of duplicating it.
# That duplication gap is what left doctor's AGENTS.md-freshness check stubbed
# and emitting a spurious "unreadable" warning on every consumer ``task doctor``
# run (#1389). Unlike the events surface, ``_agents_md`` is stdlib-only with no
# import-time side effects, so importing it here does not couple the bootstrap
# entry point to the heavier ``scripts/`` package behaviour. The v1/v2/v3 marker
# contract and provenance-attribute semantics now live there verbatim.
_scripts_dir = str(Path(__file__).resolve().parent / "scripts")
if _scripts_dir not in sys.path:
    sys.path.insert(0, _scripts_dir)
from _agents_md import (  # noqa: E402  -- pure module; intentional post-path import
    _AGENTS_MANAGED_CLOSE,
    _AGENTS_MANAGED_OPEN_RE,
    _agents_template_path,
    _attribute_render_managed_section,  # noqa: F401  -- re-exported for tests
    _extract_managed_section,
    _iter_managed_sections,
    _parse_managed_section_attrs,
    _read_agents_template,
    _render_managed_section,
    _resolve_framework_sha as _resolve_framework_sha_git,
    _strip_managed_section_attrs,
)
from _agents_md import _agents_refresh_plan as _shared_agents_refresh_plan  # noqa: E402


def _classify_agents_md(project_root: Path) -> str:
    """Return one of: `current`, `stale`, `missing`, `absent`.

    - ``absent``  -> ./AGENTS.md does not exist
    - ``missing`` -> ./AGENTS.md exists but has no managed-section markers
                     (no v1/v2/v3 open marker found)
    - ``stale``   -> markers present but bracketed bytes (after open-marker
                     normalisation) != current template render OR the open
                     marker is a legacy v1/v2 form (forces upgrade to v3)
                     OR more than one managed-section block exists in the
                     file (a partial upgrade left duplicate blocks -- #1044)
    - ``current`` -> exactly one managed block whose bracketed bytes are
                     byte-identical to current template render after
                     stripping v3 marker attributes

    A v1- or v2-marker consumer file always classifies as ``stale`` so
    the next refresh upgrades it to the v3 form (#1044 v1; #1046 PR-B
    AC-5 v2). After upgrade the v3 marker's per-refresh ``sha`` /
    ``refreshed`` / ``session`` attributes do NOT poison the staleness
    check -- ``_strip_managed_section_attrs`` normalises both sides to
    the bare ``v3`` form before comparison.

    A missing or unreadable template falls through to ``current`` so the
    gate never fires solely because the framework checkout itself is
    incomplete.
    """
    agents_md = project_root / "AGENTS.md"
    if not agents_md.is_file():
        return "absent"
    try:
        existing = agents_md.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return "absent"
    normalised = existing.replace("\r\n", "\n")
    blocks = _iter_managed_sections(normalised)
    if not blocks:
        return "missing"
    if len(blocks) > 1:
        # Multiple managed blocks present (e.g. a partial v1 -> v3
        # upgrade left the original v1 in place AND appended a v3) --
        # always stale so the refresh path collapses to a single v3.
        return "stale"
    extracted = blocks[0][2]
    attrs = _parse_managed_section_attrs(extracted)
    if attrs is not None and attrs["version"] in (1, 2):
        # v1 / v2 marker -- force upgrade to v3 by classifying as stale
        # regardless of whether the body bytes match. The legacy -> v3
        # transition is the load-bearing #1044 / #1046 PR-B AC-5 fix.
        return "stale"
    template_text = _read_agents_template()
    if template_text is None:
        # Framework checkout incomplete -- err on the side of "current"
        # so the universal gate doesn't refuse to start.
        return "current"
    rendered = _render_managed_section(template_text)
    if rendered is None:
        return "current"
    return "current" if _strip_managed_section_attrs(extracted) == rendered else "stale"


# --- Install-layout state detector + auto-prompt (#992 PR3) ----------------
#
# The deft framework supports two on-disk install layouts at the consumer
# project root: the legacy ``deft/`` directory (state A) and the canonical
# ``.deft/core/`` directory (state B; produced by current installer +
# webinstaller + sync skill + oz). v0.27 ships the relocator (#992 PR2)
# that wipes-and-reinstalls into ``.deft/core/`` from any state. PR3 adds
# the gate-side detector + auto-prompt so non-A consumers see a one-line
# advisory on every CLI invocation directing them to the relocator.
#
# Five states (per the active scope vBRIEF Problem narrative + #1046 PR-A):
#
#   A  pure ``deft/``                (legacy install; AGENTS.md + framework agree)
#   B  pure ``.deft/core/``          (current installer output; broken because
#                                     AGENTS.md may still say ``deft/``)
#   C  hybrid (both dirs present)    (broken; agents follow whichever they
#                                     read first)
#   D  AGENTS.md only                (broken partial install)
#   K  install location mismatch    (#1046 finding #2; AGENTS.md template
#                                     byte-matches current render BUT the
#                                     declared install path does not resolve
#                                     -- Case G refresh is a documented
#                                     no-op; ``task framework:doctor`` is
#                                     the right remediation, forthcoming
#                                     in PR-B of the #1046 cohort)
#
# Detection inputs (read-only filesystem probes):
#   - ``<project_root>/deft/``               legacy framework dir present?
#   - ``<project_root>/.deft/core/``         canonical framework dir present?
#   - ``<project_root>/AGENTS.md``           managed-section markers present?
#   - AGENTS.md managed-section bytes        byte-equal to current template?
#   - declared ``Full guidelines: ...``      install path resolves on disk?
#
# On detection of a non-A state the gate emits a single-line auto-prompt.
# The remediation prompt branches by state:
#   B / C / D -> ``[deft] install layout state: <X> (<description>). \
#                  Run <framework>/run relocate to upgrade. (Y/n)``
#   K         -> ``[deft] install layout state: K (<description>). \
#                  Run task framework:doctor (forthcoming in PR-B of #1046
#                  cohort) OR manually verify the install path AGENTS.md
#                  claims actually exists on disk. (Y/n)``
#
# AUTO-PROMPT ONLY -- the gate NEVER auto-invokes ``task relocate`` or
# ``task framework:doctor``, NEVER calls the interactive ``read_yn`` /
# ``ask_confirm`` helpers, and NEVER mutates filesystem state on any code
# path. Mirrors the #884 ghx-install consent gate convention: the operator
# runs the suggested remediation on consent.

_INSTALL_LAYOUT_DESCRIPTIONS = {
    "A": "pure deft/ legacy install",
    "B": "pure .deft/core/ canonical install",
    "C": "hybrid (deft/ + .deft/core/)",
    "D": "AGENTS.md only (partial install)",
    "K": (
        "install location mismatch -- AGENTS.md template byte-matches but "
        "declared install path does not resolve"
    ),
}

# Canonical relocate target -- the prompt always points at ``.deft/core``
# regardless of source state because the relocator wipes-and-reinstalls
# into that single namespace (single-namespace contract for v0.27 per the
# active scope vBRIEF DesignChoice narrative).
_INSTALL_LAYOUT_RELOCATE_TARGET = ".deft/core"

# Canonical AGENTS.md install-path declaration shape (#1046 PR-A). The
# rendered managed section emitted by ``templates/agents-entry.md`` carries
# ``Full guidelines: <root>/main.md`` immediately after the ``Deft is
# installed in <root>/.`` declaration. The Case K detector parses this
# line to discover the install path AGENTS.md claims, then checks whether
# that path resolves on disk. The first match wins -- a well-formed
# managed section carries exactly one such declaration.
_AGENTS_DECLARED_MAIN_MD_PATTERN = re.compile(
    r"Full guidelines:\s+(\S+main\.md)"
)


def _agents_md_has_managed_markers(project_root: Path) -> bool:
    """Return True iff ``./AGENTS.md`` exists and carries the managed-section markers.

    Mirrors ``_classify_agents_md`` semantics but avoids the template-render
    comparison: the install-layout detector only needs to know whether the
    file declares itself as deft-managed, not whether the bracketed bytes
    are byte-identical to the rendered template. Read-only -- never
    modifies the file. Accepts BOTH v2 and v3 open markers per the
    #1046 PR-B AC-5 back-compat parser (one-release window).
    """
    agents_md = project_root / "AGENTS.md"
    if not agents_md.is_file():
        return False
    try:
        text = agents_md.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return False
    return (
        _AGENTS_MANAGED_OPEN_RE.search(text) is not None
        and _AGENTS_MANAGED_CLOSE in text
    )


def _agents_md_declared_main_md(project_root: Path) -> Optional[str]:
    """Return the framework main.md path that AGENTS.md declares, or None (#1046 PR-A).

    Pure parse of AGENTS.md text -- locates the canonical
    ``Full guidelines: <root>/main.md`` declaration emitted by
    ``templates/agents-entry.md`` and returns the captured path (forward
    slash form). Returns None when AGENTS.md is missing, unreadable, or
    carries no such declaration. Read-only -- never modifies the file.
    """
    agents_md = project_root / "AGENTS.md"
    if not agents_md.is_file():
        return None
    try:
        text = agents_md.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None
    match = _AGENTS_DECLARED_MAIN_MD_PATTERN.search(text)
    if match is None:
        return None
    return match.group(1)


def _install_path_resolves(project_root: Path) -> bool:
    """True iff the install path AGENTS.md declares resolves on disk (#1046 PR-A).

    Reads AGENTS.md, parses the canonical ``Full guidelines:
    <root>/main.md`` declaration (e.g. ``.deft/core/main.md`` for the
    canonical install layout, ``deft/main.md`` for the legacy install
    layout), and returns True iff ``<project_root>/<declared>`` exists
    as a file. When AGENTS.md is missing or makes no such declaration,
    returns True (vacuously -- no claim to invalidate). Read-only --
    never modifies any state.

    Used by ``_classify_install_layout`` to detect Case K (#1046
    finding #2): an AGENTS.md whose managed section byte-matches the
    current template but whose declared install path does not exist on
    disk produces a documented no-op Case G refresh loop. Distinguishing
    K from the existing D classification routes the user at
    ``task framework:doctor`` (forthcoming in PR-B of the #1046 cohort)
    instead of the broken refresh path.
    """
    declared = _agents_md_declared_main_md(project_root)
    if declared is None:
        return True
    return (project_root / declared).is_file()


def _template_matches_managed_section(project_root: Path) -> bool:
    """True iff AGENTS.md's managed section equals the rendered template (#1046 PR-A).

    Thin alias over ``_classify_agents_md`` -- returns True only when
    the classifier reports ``current`` (managed-section bytes are
    byte-identical to the current ``templates/agents-entry.md`` render).
    Used by ``_classify_install_layout`` to distinguish Case K
    (template current, install path unresolved -- refresh is a no-op)
    from Case D (template stale, no install dir present -- refresh
    helps). Read-only -- never modifies any state.
    """
    return _classify_agents_md(project_root) == "current"


def _classify_install_layout(project_root: Path) -> Optional[str]:
    """Return one of ``A``, ``B``, ``C``, ``D``, ``K``, or ``None``.

    Pure read-only filesystem probe -- inspects the existence of
    ``./deft/`` and ``./.deft/core/``, the managed-section markers in
    ``./AGENTS.md``, the byte-equality of AGENTS.md's managed section
    against the current template render, and the on-disk resolution of
    the install path AGENTS.md declares. Never modifies any state.

    Mapping (per the active scope vBRIEF Problem narrative +
    #1046 PR-A AC-2):
        - ``A``    -> ``deft/`` present, ``.deft/core/`` absent
        - ``B``    -> ``deft/`` absent,  ``.deft/core/`` present
        - ``C``    -> both install dirs present (hybrid)
        - ``D``    -> neither install dir present; AGENTS.md with managed
                      markers; template content differs from the current
                      render OR the declared install path resolves
                      (refresh would help, or no Case K signal)
        - ``K``    -> neither install dir present; AGENTS.md template
                      byte-matches current rendered template; AND the
                      declared install path does not resolve on disk
                      (#1046 finding #2 -- refresh is a documented
                      no-op; ``task framework:doctor`` is the right
                      remediation, forthcoming in PR-B of the #1046
                      cohort)
        - ``None`` -> neither install dir present; no managed AGENTS.md
                      (not a deft project)

    Priority: directory presence (A/B/C) takes precedence over content
    classification (D/K). When ``deft/`` is on disk and AGENTS.md's
    template content is current, the classifier returns A because A is
    by definition the layout in which AGENTS.md and the framework agree
    -- the K branch only fires when no install dir anchors the legacy
    or canonical contract.
    """
    deft_present = (project_root / "deft").is_dir()
    dotdeft_present = (project_root / ".deft" / "core").is_dir()
    if deft_present and dotdeft_present:
        return "C"
    if deft_present:
        return "A"
    if dotdeft_present:
        return "B"
    if not _agents_md_has_managed_markers(project_root):
        return None
    # AGENTS.md is managed but no install dir is present. Distinguish
    # K (template current; refresh is a no-op -- #1046 finding #2) from
    # D (template stale OR install path still resolves; refresh helps).
    if (
        _template_matches_managed_section(project_root)
        and not _install_path_resolves(project_root)
    ):
        return "K"
    return "D"


def _format_install_layout_prompt(state: str) -> str:
    """Render the one-line auto-prompt for a non-A install-layout state.

    Pure -- no I/O. Returns the single-line stdout surface consumed by
    operators reading CLI output. The prompt asks ``(Y/n)`` purely as a
    visual consent affordance; the gate NEVER acts on the answer.

    Branches:
      * ``B`` / ``C`` / ``D`` -- the relocator
        (``.deft/core/run relocate``) is the canonical remediation
        (single-namespace contract per #992).
      * ``K`` -- install-location mismatch surfaced by #1046 PR-A. The
        relocator does not fix this state (template content is already
        current); the right remediation is ``task framework:doctor``
        (forthcoming in PR-B of the #1046 cohort). Until PR-B merges
        the prompt advises a manual install-path check.
    """
    description = _INSTALL_LAYOUT_DESCRIPTIONS.get(state, "")
    if state == "K":
        return (
            f"[deft] install layout state: {state} ({description}). "
            f"Run task framework:doctor (forthcoming in PR-B of #1046 "
            f"cohort) OR manually verify the install path AGENTS.md "
            f"claims actually exists on disk. (Y/n)"
        )
    framework = _INSTALL_LAYOUT_RELOCATE_TARGET
    return (
        f"[deft] install layout state: {state} ({description}). "
        f"Run {framework}/run relocate to upgrade. (Y/n)"
    )


def _maybe_emit_install_layout_prompt(project_root: Path) -> Optional[str]:
    """Print (and return) the install-layout auto-prompt on non-A states.

    Returns the emitted prompt string when a prompt was printed; returns
    ``None`` when the state is A or undetectable (not a deft project).
    NEVER mutates filesystem state and NEVER invokes ``task relocate``
    automatically -- operator consent is required for any remediation.

    The prompt is informational (single line, exit 0 path); it does NOT
    set ``needs_prompt`` in ``_check_upgrade_gate`` so the existing
    ``Continue anyway?`` blocking prompt path is not triggered solely
    because the install layout has drifted.
    """
    state = _classify_install_layout(project_root)
    if state is None or state == "A":
        return None
    line = _format_install_layout_prompt(state)
    print(line)
    return line


def _build_gate_state(project_root: Path) -> dict:
    """Compute the full state vector consumed by both cmd_gate and the JSON
    surface. Pure -- no I/O outside ``project_root`` and the framework
    template. Reuses ``_read_version_marker`` (#410), ``_detect_pre_cutover_legacy``
    (#410), ``_running_inside_deft_repo`` (#410), and the dynamic
    ``VERSION`` (#741) so the gate inherits every existing detection rule.
    """
    recorded = _read_version_marker(project_root)
    legacy = _detect_pre_cutover_legacy(project_root)
    agents_md = _classify_agents_md(project_root)
    inside_deft = _running_inside_deft_repo(project_root)
    return {
        "current": VERSION,
        "recorded": recorded,
        "precutover": list(legacy),
        "agents-md": agents_md,
        "inside_deft_repo": inside_deft,
    }


def _gate_state_is_ok(state: dict) -> bool:
    """Return True iff the state vector indicates no upgrade work needed."""
    if state.get("inside_deft_repo"):
        # Maintainer working inside the deft repo itself -- the gate stays
        # green so framework dev is never blocked by the consumer-facing
        # upgrade flow.
        return True
    recorded = state.get("recorded")
    current = state.get("current")
    precutover = state.get("precutover") or []
    agents_md = state.get("agents-md")
    if precutover:
        return False
    if recorded is not None and recorded != current:
        return False
    if agents_md == "stale":
        return False
    if agents_md == "missing":
        return False
    # All other states pass: a marker that matches `current`, or no marker
    # with no precutover artifacts and `agents-md=absent` (indistinguishable
    # from "not a deft project" -- mirrors `_check_upgrade_gate`'s
    # heuristic). Both branches converge here, so a single trailing
    # `return True` covers them.
    return True


def _format_gate_line(state: dict) -> str:
    """Render the one-line text surface consumed by the AGENTS.md preamble."""
    if _gate_state_is_ok(state):
        return f"OK v{state['current']}"
    recorded = state.get("recorded") or "unknown"
    precutover = ",".join(state.get("precutover") or [])
    agents_md = state.get("agents-md") or "absent"
    return (
        "NEEDS-UPGRADE "
        f"recorded={recorded} "
        f"current={state['current']} "
        f"precutover={precutover} "
        f"agents-md={agents_md}"
    )


def cmd_gate(args: List[str]):
    """Read-only universal upgrade gate (#768).

    Emits a single line (or a JSON object with ``--json``) describing the
    consumer project's deft state vector. Exit code is 0 when no upgrade
    work is needed, 1 otherwise. NEVER writes the marker, NEVER touches
    AGENTS.md, NEVER runs migration -- it is a probe.

    Output shapes::

        OK v<current>
        NEEDS-UPGRADE recorded=<recorded|unknown> current=<current> \
            precutover=<csv|empty> agents-md=<current|stale|missing|absent>

    The agent-readable preamble in `main.md`, `SKILL.md`, and the legacy
    redirect stubs (`skills/deft-setup/SKILL.md`, `skills/deft-build/SKILL.md`)
    runs this command before any other instruction; on a non-zero exit the
    agent reads `deft/UPGRADING.md` and follows the section whose
    "Applies when" clause matches the printed state vector.
    """
    json_mode = "--json" in args
    project_root = Path.cwd()
    state = _build_gate_state(project_root)
    if json_mode:
        payload = {
            "status": "ok" if _gate_state_is_ok(state) else "needs-upgrade",
            "current": state["current"],
            "recorded": state["recorded"],
            "precutover": state["precutover"],
            "agents-md": state["agents-md"],
            "inside_deft_repo": state["inside_deft_repo"],
        }
        print(json.dumps(payload, sort_keys=True))
    else:
        print(_format_gate_line(state))
    return 0 if _gate_state_is_ok(state) else 1


# Environment variable the agent runtime may export to identify the
# current session lineage. When set, ``_maybe_warn_same_session_refresh``
# compares the value against the embedded ``session=`` token on the
# managed-section marker to detect Case G no-op re-entry within the
# same session (#1046 finding #6).
_ENV_SESSION_ID = "DEFT_SESSION_ID"


# --- Canonical install manifest (#1046 PR-B AC-4) --------------------------
#
# The YAML provenance file at ``<install>/VERSION`` is the canonical install
# manifest (#1046 finding #4 fix-shape). It carries the install-time
# provenance ``oz-agent-upgrade`` already produces:
#
#     ref: 'v0.27.1'
#     sha: 'af829f4ec5bbe6ef562722d76080bb94ba893f8e'
#     tag: 'v0.27.1'
#     fetched_at: '2026-05-11T15:30:52Z'
#     fetched_by: 'oz-agent-upgrade'
#
# ``<project-root>/.deft-version`` (bare version) becomes a derivative
# regenerated at install time from the manifest's ``tag`` field (with the
# leading ``v`` stripped). ``framework_doctor`` check #3 verifies the two
# are in agreement; on drift, prefer the YAML manifest.

_INSTALL_MANIFEST_FILENAME = "VERSION"

# Minimal single-line ``key: value`` parser for the YAML provenance file.
# Values are stripped of surrounding single / double quotes. Lines that
# do not match are ignored so a free-form comment header does not break
# the parse. Stdlib-only -- the framework's ``cmd_install`` path cannot
# assume PyYAML is installed.
_INSTALL_MANIFEST_LINE_RE = re.compile(
    r"^\s*(?P<key>[A-Za-z_][A-Za-z0-9_]*)\s*:\s*(?P<value>.*?)\s*$"
)


def _install_manifest_path(install_root: Path) -> Path:
    """Return the canonical ``<install>/VERSION`` manifest path (#1046 PR-B)."""
    return install_root / _INSTALL_MANIFEST_FILENAME


def _parse_install_manifest(text: str) -> dict:
    """Parse a YAML-ish provenance manifest body (#1046 PR-B AC-4).

    Returns a dict of recognised string fields. Tolerates trailing /
    leading whitespace, single-quoted / double-quoted values, and
    free-form comment lines (any line not matching ``key: value`` is
    silently dropped). Empty input returns an empty dict. Pure -- no I/O.
    """
    parsed: dict = {}
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        match = _INSTALL_MANIFEST_LINE_RE.match(stripped)
        if match is None:
            continue
        key = match.group("key").strip().lower()
        value = match.group("value").strip().strip("'\"")
        if key:
            parsed[key] = value
    return parsed


def _read_install_manifest(install_root: Path) -> Optional[dict]:
    """Read the canonical install manifest at ``<install>/VERSION`` (#1046 PR-B AC-4).

    Returns the parsed dict on success, or None when the file is absent
    / unreadable. Best-effort: a malformed file returns the partial
    parse rather than raising so the gate / doctor can still surface a
    meaningful drift report.
    """
    candidate = _install_manifest_path(install_root)
    if not candidate.is_file():
        return None
    try:
        text = candidate.read_text(encoding="utf-8")
    except OSError:
        return None
    return _parse_install_manifest(text)


def _resolve_framework_sha(install_root: Optional[Path] = None) -> str:
    """Resolve the framework checkout's sha, manifest-first (#1332).

    On a vendored ``.deft/core/`` install with no nested ``.git``, running
    ``git rev-parse HEAD`` rooted at the framework dir walks up to the
    CONSUMER repo and returns the consumer's HEAD -- the wrong sha. The
    canonical install manifest's ``sha`` field records the framework's true
    sha, so prefer it. Falls back to the git resolver (used for
    framework-self-dev, where the framework root IS a git checkout) when no
    manifest sha is available.
    """
    candidates: List[Path] = []
    if install_root is not None:
        candidates.append(install_root)
    else:
        cwd = Path.cwd()
        candidates.extend([cwd / ".deft" / "core", cwd / "deft"])
    for root in candidates:
        manifest = _read_install_manifest(root)
        if manifest:
            sha = (manifest.get("sha") or "").strip()
            if sha:
                return sha
    return _resolve_framework_sha_git()


def _install_manifest_tag_to_version(manifest: dict) -> Optional[str]:
    """Derive the bare ``.deft-version`` value from a manifest (#1046 PR-B AC-4).

    Prefers ``tag`` over ``ref`` (both YAML provenance keys produced by
    ``oz-agent-upgrade``). Strips the leading ``v`` so the derivative
    file format matches the v0.27 bare-file shape (``0.27.1`` not
    ``v0.27.1``). Returns None when neither key is present.
    """
    for key in ("tag", "ref"):
        raw = manifest.get(key)
        if not isinstance(raw, str):
            continue
        candidate = raw.strip().lstrip("v")
        if candidate:
            return candidate
    return None


def _derive_install_root_string(install_root: Path, project_root: Path) -> str:
    """Return the relative install root string for the manifest (#1062).

    Computes ``install_root.relative_to(project_root)`` and renders it as
    a POSIX-style forward-slash path so the manifest shape stays
    consistent on Windows (``.deft/core`` not ``.deft\\core``). When
    ``install_root`` is not under ``project_root`` (a defensive case --
    callers should never construct this) the absolute path is returned
    as a POSIX string so the field is still populated.
    """
    try:
        rel = install_root.resolve().relative_to(project_root.resolve())
    except ValueError:
        return install_root.resolve().as_posix()
    return rel.as_posix()


def _build_install_manifest_text(
    *,
    tag: str,
    sha: str,
    fetched_at: str,
    fetched_by: str,
    install_root: str,
    ref: Optional[str] = None,
) -> str:
    """Render the canonical YAML provenance manifest text (#1046 PR-B AC-4, #1062).

    Pure -- no I/O. Mirrors the ``oz-agent-upgrade`` shape (single-quoted
    values, ordered ref/sha/tag/install_root/fetched_at/fetched_by) so a
    doctor probe that re-reads after a ``cmd_install`` write does not
    flag a shape mismatch. Both ``ref`` and ``tag`` are normalised to the
    ``v<X.Y.Z>`` tag-reference form to match the ``oz-agent-upgrade``
    rail and the documented shape in ``docs/install-manifest.md``;
    ``ref`` defaults to the normalised tag when None. The bare-derivative
    regeneration path (``_install_manifest_tag_to_version``)
    ``lstrip("v")`` so the derivative ``.deft-version`` still ends up as
    ``0.27.1``.

    The ``install_root`` field (#1062) is the relative POSIX-style path
    from the consumer project root to the framework deposit (e.g.
    ``.deft/core`` for canonical installs, ``deft`` for legacy state-A).
    The doctor consumer reads this field as the single source of truth
    for the install-layout contract instead of parsing AGENTS.md prose.
    """
    # Normalise both ref and tag to the v-prefixed tag-reference form so
    # consumers reading the raw YAML (oz-agent-upgrade pipeline, doctor
    # report, external tooling) see one consistent shape regardless of
    # whether the caller passed ``"0.27.1"`` or ``"v0.27.1"`` (#1046 PR-B,
    # Greptile review #1057). Prior to this fix ``ref`` was v-prefixed but
    # ``tag`` was bare -- the mismatch was harmless for internal use
    # (lstrip handles both) but diverged from documented contract.
    effective_tag = tag if tag.startswith("v") else f"v{tag}"
    effective_ref = ref if ref is not None else effective_tag
    lines = [
        f"ref: '{effective_ref}'",
        f"sha: '{sha}'",
        f"tag: '{effective_tag}'",
        f"install_root: '{install_root}'",
        f"fetched_at: '{fetched_at}'",
        f"fetched_by: '{fetched_by}'",
    ]
    return "\n".join(lines) + "\n"


def _write_install_manifest(
    install_root: Path,
    *,
    fetched_by: str,
    project_root: Optional[Path] = None,
    tag: Optional[str] = None,
    sha: Optional[str] = None,
    fetched_at: Optional[str] = None,
) -> Optional[Path]:
    """Write the canonical install manifest at ``<install>/VERSION`` (#1046 PR-B AC-4, #1062).

    Best-effort: silently degrades on OSError (read-only filesystem,
    permission denied) rather than crashing the install flow. Returns
    the manifest path on success, None on failure. ``tag`` defaults to
    ``VERSION`` (the run-resolved framework version) when None;
    ``sha`` defaults to ``_resolve_framework_sha()`` when None;
    ``fetched_at`` defaults to ``_now_utc_iso()`` when None.
    ``project_root`` defaults to ``install_root.parent`` when None --
    callers SHOULD pass the explicit consumer project root so the
    derived ``install_root`` field reflects the full layout-relative
    path (e.g. ``.deft/core`` rather than just ``core``).

    The companion bare ``.deft-version`` file is regenerated from the
    manifest's ``tag`` field by ``cmd_install`` / ``cmd_upgrade`` so
    the two stay in sync on every install.
    """
    effective_tag = tag if tag is not None else VERSION
    # #1454: never persist the dev-checkout sentinel into a consumer
    # manifest -- a `0.0.0-dev` resolution must not clobber the real
    # `<install>/VERSION` provenance. Preserve any prior manifest by
    # skipping the write (return None, mirroring the OSError degrade).
    if effective_tag.lstrip("v") == _DEV_VERSION_SENTINEL:
        return None
    effective_sha = sha if sha is not None else _resolve_framework_sha(install_root)
    effective_fetched_at = fetched_at if fetched_at is not None else _now_utc_iso()
    effective_project_root = project_root if project_root is not None else install_root.parent
    install_root_str = _derive_install_root_string(install_root, effective_project_root)
    body = _build_install_manifest_text(
        tag=effective_tag,
        sha=effective_sha,
        fetched_at=effective_fetched_at,
        fetched_by=fetched_by,
        install_root=install_root_str,
    )
    path = _install_manifest_path(install_root)
    try:
        install_root.mkdir(parents=True, exist_ok=True)
        path.write_text(body, encoding="utf-8")
    except OSError:
        return None
    return path


def _migrate_legacy_install_manifest(
    project_root: Path, canonical_manifest_path: Optional[Path]
) -> None:
    """Back up a stale parent-level ``.deft/VERSION`` after migration (#1325).

    The canonical install manifest lives at ``.deft/core/VERSION``. A legacy
    parent-level ``.deft/VERSION`` (e.g. left by an older webinstaller) that
    DIFFERS from the canonical manifest is a stale source-of-truth: doctor's
    manifest-agreement check would flag it and downstream version resolution
    could read the wrong value. Rename it to ``.deft/VERSION.premigrate`` so
    the canonical manifest is the sole authority, emitting one info line.

    Only fires when the canonical manifest is the ``.deft/core/VERSION``
    deposit (the parent-of-install relationship that defines "legacy"); a
    legacy state-A ``deft/`` install has no such parent-level file to
    migrate. Best-effort -- never raises.
    """
    if canonical_manifest_path is None:
        return
    canonical = Path(canonical_manifest_path)
    legacy = project_root / ".deft" / "VERSION"
    try:
        if canonical.resolve().parent != (project_root / ".deft" / "core").resolve():
            return
        if not legacy.is_file():
            return
        legacy_version = _install_manifest_tag_to_version(
            _parse_install_manifest(legacy.read_text(encoding="utf-8"))
        )
        canonical_version = _install_manifest_tag_to_version(
            _parse_install_manifest(canonical.read_text(encoding="utf-8"))
        )
        if legacy_version is not None and legacy_version == canonical_version:
            return  # manifests agree -> nothing stale to migrate
        backup = project_root / ".deft" / "VERSION.premigrate"
        legacy.replace(backup)
        info(
            "Moved legacy install manifest from .deft/VERSION -> "
            f".deft/core/VERSION. Backup at {backup}."
        )
    except OSError:
        return


def _agents_refresh_plan(project_root: Path) -> dict:
    """Compute the AGENTS.md refresh plan, routing run's patchable seams (#1389).

    The pure plan logic now lives in ``scripts/_agents_md.py`` (the single
    source of truth shared with ``scripts/doctor.py``). This thin wrapper
    injects ``run``'s ``_read_agents_template`` so the existing
    monkeypatch-based tests -- which patch ``deft_run._read_agents_template``
    -- continue to drive the shared implementation unchanged. The sha /
    session / timestamp seams are deterministic and identical across both
    modules, so the plan uses the shared module's own helpers for those.
    """
    return _shared_agents_refresh_plan(
        project_root,
        read_template=_read_agents_template,
    )


def cmd_agents_refresh(args: List[str]):
    """Python reference implementation of the AGENTS.md contract (#768).

    Modes:
        ``--check``   -> exit 0 iff the consumer's managed section is
                        byte-identical to the rendered template; non-zero
                        otherwise. Never writes.
        ``--dry-run`` -> print the planned change; never writes.
        (default)     -> apply the planned change idempotently, handling
                        the four states (`current`/`stale`/`missing`/`absent`).

    The bracketed region is the SOLE byte sequence the framework owns.
    Content above or below the markers is preserved verbatim, so consumer
    notes survive every refresh.
    """
    check = "--check" in args
    dry_run = "--dry-run" in args
    project_root = Path.cwd()
    plan = _agents_refresh_plan(project_root)
    state = plan["state"]

    if state == "template-missing":
        if check:
            return 1
        error(
            "AGENTS.md template not found at "
            f"{_agents_template_path()} -- skipping refresh."
        )
        return 1
    if state == "template-malformed":
        if check:
            return 1
        error(
            "AGENTS.md template is missing the deft:managed-section markers "
            "-- skipping refresh."
        )
        return 1
    if state == "unreadable":
        if check:
            return 1
        error(f"AGENTS.md exists but is unreadable: {plan.get('error', '')}")
        return 1

    if check:
        # `--check` only succeeds when the file already exists with the
        # exact rendered managed-section bytes. `absent` and `missing`
        # both need a write, so they fail the check.
        return 0 if state == "current" else 1

    if dry_run:
        print(f"AGENTS.md state: {state}")
        print(f"Path: {plan['path']}")
        if state == "current":
            print("Plan: no-op (managed section already current)")
            return 0
        if state == "absent":
            print("Plan: create AGENTS.md from rendered template")
        elif state == "missing":
            print(
                "Plan: wrap existing content above the new managed section "
                "(one-time legacy migration)"
            )
        elif state == "stale":
            print("Plan: byte-replace managed section with rendered template")
        return 0

    if state == "current":
        # Idempotent no-op; align with cmd_upgrade's quiet success path.
        info("AGENTS.md managed section already current.")
        return 0

    new_content = plan["new_content"]
    target = Path(plan["path"])
    try:
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(new_content, encoding="utf-8")
    except OSError as exc:
        error(f"Could not write AGENTS.md: {exc}")
        return 1

    if state == "absent":
        success(f"Created AGENTS.md from template at {target}.")
    elif state == "missing":
        success(
            "Wrapped existing AGENTS.md content above the new managed "
            "section (one-time legacy migration)."
        )
    elif state == "stale":
        success("Refreshed AGENTS.md managed section to current template.")
    return 0


def cmd_check_updates(args: List[str]):
    """Read-only periodic remote-version probe (#801).

    Runs ``git ls-remote --tags --refs <upstream>`` against the framework's
    upstream remote (resolved from the consumer's ``./deft`` submodule, or
    the run-rooted repo when invoked from the framework checkout itself)
    and compares the highest semver tag to the in-process ``VERSION``.

    Output shapes (text mode)::

        OK upstream=<tag>
        BEHIND upstream=<tag> current=v<version> commits-behind=unknown
        NO-UPSTREAM current=v<version>
        NO-TAGS current=v<version> upstream=<url>
        ERROR current=v<version> upstream=<url> error=<msg>
        SKIPPED reason=DEFT_NO_NETWORK current=v<version>

    ``--json`` emits the same axes as a single JSON object on stdout.
    Exit code is 1 only on the BEHIND status (so ``task
    framework:check-updates`` returns non-zero when an upstream release is
    available); every other status returns 0 because the probe itself
    succeeded -- the consumer can choose to treat ``no-upstream`` /
    ``error`` as informational.

    Honors:
        DEFT_NO_NETWORK=1            -- silent skip, exit 0
        DEFT_REMOTE_PROBE_TIMEOUT    -- subprocess timeout (default 5s)
        DEFT_FORCE_REMOTE_PROBE=1    -- bypass throttle (used by
                                        ``task framework:check-updates -- --force``)

    NEVER writes; NEVER runs ``git fetch``. The throttle file at
    ``vbrief/.deft-remote-probe.json`` is updated only when the probe is
    invoked through the upgrade gate (``_maybe_emit_remote_drift_warning``);
    the CLI surface is intentionally idempotent so consumers can call it
    on demand without poisoning the cadence.
    """
    json_mode = "--json" in args
    project_root = Path.cwd()
    result = _run_remote_probe(project_root)
    status = result.get("status", "error")
    if json_mode:
        print(json.dumps(result, sort_keys=True))
    else:
        if status == "ok":
            print(f"OK upstream={result['remote']}")
        elif status == "behind":
            print(
                f"BEHIND upstream={result['remote']} "
                f"current=v{result['current']} "
                "commits-behind=unknown"
            )
        elif status == "skipped":
            print(
                f"SKIPPED reason=DEFT_NO_NETWORK "
                f"current=v{result['current']}"
            )
        elif status == "no-upstream":
            print(f"NO-UPSTREAM current=v{result['current']}")
        elif status == "no-tags":
            print(
                f"NO-TAGS current=v{result['current']} "
                f"upstream={result.get('upstream_url', '')}"
            )
        else:  # error
            print(
                f"ERROR current=v{result['current']} "
                f"upstream={result.get('upstream_url', '')} "
                f"error={result.get('error', 'unknown')}"
            )
    return 1 if status == "behind" else 0


def cmd_upgrade(args: List[str]):
    """Acknowledge the framework upgrade and write the `.deft-version` marker.

    This command only records the framework version so the upgrade gate stops
    warning.  It delegates the heavy lifting (SPECIFICATION.md / PROJECT.md
    migration, lifecycle folder creation) to `task migrate:vbrief`.

    #768: also calls ``cmd_agents_refresh`` so the AGENTS.md managed
    section is brought to the current rendered template alongside the
    marker write -- closes the stale-AGENTS.md adoption-blocker without
    requiring a separate manual step.
    """
    print_header(f"Deft CLI v{VERSION} - Upgrade")
    print()
    project_root = Path.cwd()
    recorded = _read_version_marker(project_root)
    if recorded == VERSION:
        success(f"Project already at {VERSION}. Nothing to do.")
        # Still refresh AGENTS.md in case the consumer's marker is current
        # but the template moved -- byte-stable when already at the latest.
        # Greptile P1: propagate the refresh return code so a failed AGENTS.md
        # write surfaces as a non-zero `.deft/core/run upgrade` exit instead of
        # leaving the project partially upgraded with a silent success.
        return cmd_agents_refresh([])

    legacy = _detect_pre_cutover_legacy(project_root)
    if legacy:
        warn(
            "Pre-v0.20 document model detected ("
            + ", ".join(legacy)
            + "). Run `task migrate:vbrief` first -- it migrates legacy "
            "artifacts and creates the lifecycle folder structure. This "
            "command only records the framework version."
        )

    vbrief_dir = project_root / "vbrief"
    target_dir = vbrief_dir if vbrief_dir.is_dir() else project_root
    _write_version_marker(target_dir)

    # #1046 PR-B AC-4: write the canonical YAML provenance manifest at
    # ``<install>/VERSION``. The install root is wherever the framework
    # is laid out on disk (``.deft/core`` for canonical installs;
    # ``deft`` for legacy state-A installs). Best-effort -- a missing
    # install directory silently skips the write (the bare
    # ``.deft-version`` is still recorded above).
    written_manifest_path: Optional[Path] = None
    for install_candidate in (
        project_root / ".deft" / "core",
        project_root / "deft",
    ):
        if install_candidate.is_dir():
            written_manifest_path = _write_install_manifest(
                install_candidate,
                fetched_by="run-upgrade",
                project_root=project_root,
            )
            break

    # #1325: a legacy parent-level `.deft/VERSION` left behind after the
    # canonical manifest moved to `.deft/core/VERSION` is a stale
    # source-of-truth -- migrate it (rename to `.deft/VERSION.premigrate`)
    # when it disagrees with the canonical manifest just written.
    _migrate_legacy_install_manifest(project_root, written_manifest_path)

    if recorded is None:
        success(f"Recorded framework version {VERSION} in .deft-version.")
    else:
        success(f"Updated .deft-version from {recorded} to {VERSION}.")
    info(
        "If legacy SPECIFICATION.md or PROJECT.md content remains, run "
        "`task migrate:vbrief` to complete the upgrade."
    )
    # #768: bring AGENTS.md to the current template alongside the marker.
    # Greptile P1: propagate the refresh return code so a failed AGENTS.md
    # write surfaces as a non-zero `.deft/core/run upgrade` exit instead of
    # leaving the project partially upgraded with a silent success.
    return cmd_agents_refresh([])


def cmd_bootstrap(args: List[str]):
    """Bootstrap command - set up user.md"""
    print_header(f"Deft CLI v{VERSION} - Bootstrap")
    print()
    info("This command creates user.md, which defines YOUR personal preferences:")
    info("  • Your name (how the AI should address you)")
    info("  • Primary programming languages")
    info("  • Default test coverage threshold")
    info("  • Development strategy")
    info("  • Custom rules and experimental guidelines")
    print()
    info("These preferences apply across all your projects and only need to be set once.")
    info("You can update them anytime by editing user.md or re-running bootstrap.")
    print()
    
    defaults = get_default_paths()
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['user']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    if 'output_path' not in progress:
        print_section("Output Location")
    user_path_str = _resume_or_ask(progress, prog_file, 'output_path', 'Output',
                                    read_input, "Where to write USER.md", defaults['user'])
    user_file = resolve_path(user_path_str)
    
    # Check if file exists (skip when resuming — user already committed)
    if not progress.get('user_name'):
        if user_file.exists() and "--force" not in args:
            info(f"USER.md already exists at {user_file}")
            if not read_yn("Overwrite with new preferences?"):
                success("Keeping existing USER.md as-is.")
                print()
                # Still offer next steps even when keeping existing file
                print_section("Next Steps")
                if read_yn("Would you like to run 'run project' now?", default=True):
                    print()
                    return cmd_project([])
                else:
                    print()
                    info("You can run 'run project' later to configure your project")
                    return 0
    
    if 'user_name' not in progress:
        print()
        print_section("User Preferences Setup")
    
    # Gather user information
    user_name = _resume_or_ask(progress, prog_file, 'user_name', 'Name',
                                read_input, "Your name (how AI should address you)")
    if 'coverage' not in progress:
        while True:
            coverage = read_input("Default coverage threshold (default: 85%)", "85")
            if not coverage.strip():
                coverage = "85"
                break
            try:
                val = int(coverage.strip())
                if 1 <= val <= 100:
                    break
            except ValueError:
                pass
            print_error("Please enter a number between 1 and 100.")
        progress['coverage'] = coverage
        _save_progress(prog_file, progress)
    else:
        coverage = progress['coverage']
        info(f"  [resumed] Coverage: {coverage}")
    
    available_langs = get_available_languages()
    other_num = len(available_langs) + 1
    valid_lang_nums = set(str(i) for i in range(1, other_num + 1))
    if 'lang_selection' not in progress:
        print()
        print_section("Programming Languages")
        info("Select your primary programming languages (comma-separated):")
        for i, (stem, display) in enumerate(available_langs, 1):
            print(f"  {i}. {display}")
        print(f"  {other_num}. Other")
        while True:
            lang_selection = read_input("Selection (e.g., 1,3 or Enter to skip)")
            if not lang_selection.strip():
                break  # Skip
            nums = [s.strip() for s in lang_selection.split(',')]
            if len(nums) != len(set(nums)):
                print_error("Duplicate selections are not allowed.")
                continue
            if all(n in valid_lang_nums for n in nums):
                break
            print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        progress['lang_selection'] = lang_selection
        _save_progress(prog_file, progress)
    else:
        lang_selection = progress['lang_selection']
        info(f"  [resumed] Languages: {lang_selection or '(skipped)'}")
    
    lang_nums = [s.strip() for s in lang_selection.split(',')]
    languages = []
    for num in lang_nums:
        try:
            idx = int(num) - 1
            if 0 <= idx < len(available_langs):
                languages.append(f"- {available_langs[idx][1]}")
            elif int(num) == other_num:
                other_lang = _resume_or_ask(progress, prog_file, 'other_lang',
                                            'Other language', read_input, "Enter language name")
                if other_lang:
                    languages.append(f"- {other_lang}")
        except ValueError:
            pass
    
    languages_str = '\n'.join(languages) if languages else "- (None specified)"
    
    available_strats = get_available_strategies()
    max_strat = len(available_strats)
    # Default to 'interview' strategy if available, otherwise first
    default_strat_num = "1"
    for i, (stem, _) in enumerate(available_strats, 1):
        if stem.lower() == "interview":
            default_strat_num = str(i)
            break
    if 'strat_selection' not in progress:
        if max_strat == 0:
            warn("No strategy files found in strategies/ — defaulting to Interview.")
            strat_selection = "1"
        else:
            print()
            print_section("Development Strategy")
            info("Select your default development strategy:")
            for i, (stem, display) in enumerate(available_strats, 1):
                desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                marker = " ★ RECOMMENDED" if str(i) == default_strat_num else ""
                print(f"  {i}. {display}{marker}")
                if desc:
                    print(f"     {desc}")
            print()
            info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
            while True:
                strat_selection = read_input("Selection", default_strat_num)
                if not strat_selection.strip():
                    strat_selection = default_strat_num
                    break
                try:
                    num = int(strat_selection.strip())
                    if 1 <= num <= max_strat:
                        break
                except ValueError:
                    pass
                print_error(f"Please enter a number between 1 and {max_strat}.")
        progress['strat_selection'] = strat_selection
        _save_progress(prog_file, progress)
    else:
        strat_selection = progress['strat_selection']
        info(f"  [resumed] Strategy: {strat_selection}")
    
    try:
        strat_idx = int(strat_selection.strip()) - 1
        if 0 <= strat_idx < len(available_strats):
            selected_strategy = available_strats[strat_idx]
        else:
            selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    except ValueError:
        selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    strategy_stem, strategy_display = selected_strategy
    
    showed_custom_rules_header = 'has_custom_rules' not in progress
    if 'has_custom_rules' not in progress:
        print()
        print_section("Custom Rules")
        info("Add rules the AI must always follow (optional). Enter one rule per line, empty line to finish.")
        has_rules = read_yn("Do you have custom rules to add?")
        progress['has_custom_rules'] = has_rules
        _save_progress(prog_file, progress)
    else:
        has_rules = progress['has_custom_rules']

    if 'custom_rules' not in progress:
        if has_rules:
            if not showed_custom_rules_header:
                print()
                print_section("Custom Rules")
                info("Continuing rule collection (interrupted mid-loop). Empty line to finish.")
                print()
            rules_list = list(progress.get('custom_rules_wip', []))
            if rules_list:
                info(f"  [resumed] {len(rules_list)} rule(s) already collected:")
                for r in rules_list:
                    info(f"    {r}")
            while True:
                rule = read_input("  Rule (or Enter to finish)")
                if not rule.strip():
                    break
                rules_list.append(f"- {rule.strip().lstrip('- ').strip()}")
                progress['custom_rules_wip'] = rules_list
                _save_progress(prog_file, progress)
            custom_rules = '\n'.join(rules_list) if rules_list else ""
        else:
            custom_rules = ""
        progress['custom_rules'] = custom_rules
        progress.pop('custom_rules_wip', None)
        _save_progress(prog_file, progress)
    else:
        custom_rules = progress['custom_rules']
        display = custom_rules.replace('\n', '; ')
        info(f"  [resumed] Custom rules: {display[:60] + '...' if len(custom_rules) > 60 else display or '(none)'}")
    
    if any(k not in progress for k in ('use_soul', 'use_morals', 'use_code_field')):
        print()
        print_section("Meta Guidelines")
        info("Deft ships three meta-guidelines that shape how the AI behaves. All are included")
        info("by default — press Enter to keep each, or n to drop it.")
        print()
        info("SOUL.md — Results-first agent persona (inspired by Winston Wolf).")
        info("  Enforces assess-before-acting, finish-what-you-start, right-tool-for-the-job,")
        info("  and play-the-long-game. Keeps the AI decisive and concise rather than narrating")
        info("  every step. Includes a named persona ('Vinston') — drop if you prefer to define")
        info("  your own agent personality.")
        print()
        info("morals.md — Epistemic honesty rules.")
        info("  No presenting speculation as fact, label unverified claims, self-correct when")
        info("  wrong. Foundational trust rules for any AI agent. Strongly recommended.")
        print()
        info("code-field.md — Pre-code assumption protocol.")
        info("  Requires stating assumptions, naming failure modes, and writing only code the AI")
        info("  can defend — before writing a single line. Fights the 'it compiles, ship it'")
        info("  instinct. Based on the NeoVertex1 context-field framework.")
        print()
    use_soul = _resume_or_ask(progress, prog_file, 'use_soul', 'SOUL.md',
                               read_yn, "Include meta/SOUL.md? (Results-first persona)", default=True)
    use_morals = _resume_or_ask(progress, prog_file, 'use_morals', 'morals.md',
                                 read_yn, "Include meta/morals.md? (Epistemic honesty rules)", default=True)
    use_code_field = _resume_or_ask(progress, prog_file, 'use_code_field', 'code-field.md',
                                     read_yn, "Include meta/code-field.md? (Pre-code assumption protocol)", default=True)
    
    # Build experimental rules section
    experimental_rules = []
    if use_soul:
        experimental_rules.append("- ! Use meta/SOUL.md for strategic context and purpose-driven guidance")
    if use_morals:
        experimental_rules.append("- ! Use meta/morals.md for ethical AI development principles")
    if use_code_field:
        experimental_rules.append("- ~ Use meta/code-field.md for advanced architecture patterns")
    
    experimental_section = ""
    if experimental_rules:
        experimental_section = "\n## Experimental Rules\n\n" + "\n".join(experimental_rules)
    
    # Build coverage override line (only if non-default)
    coverage_line = f"\n**Coverage**: ! ≥{coverage}% test coverage" if coverage != "85" else ""
    
    # Build strategy line (omit link when no strategy files exist)
    if available_strats:
        strategy_line = f"**Default Strategy**: [{strategy_display}](../strategies/{strategy_stem}.md)"
    else:
        strategy_line = f"**Default Strategy**: {strategy_display}"
    
    # Generate user.md
    user_content = f"""# User Preferences

Legend (from RFC2119): !=MUST, ~=SHOULD, ≉=SHOULD NOT, ⊗=MUST NOT, ?=MAY.

## Personal (always wins)

Settings in this section have HIGHEST precedence — override all other deft rules,
including PROJECT.md.

**Name**: Address the user as: **{user_name}**

**Custom Rules**:
{custom_rules if custom_rules else "No custom rules defined yet."}

## Defaults (fallback)

Settings in this section are fallback defaults. PROJECT.md overrides these
for project-scoped settings (strategy, coverage, languages).

**Primary Languages**:
{languages_str}

{strategy_line}
{coverage_line}
{experimental_section}

---

**Note**: You can edit this file anytime to update your preferences.
**See**: [../main.md](../main.md) for framework defaults.
"""
    
    _atomic_write(user_file, user_content)
    _clear_progress(prog_file)
    
    success(f"Created user.md at {user_file}")
    print()
    info("user.md defines your personal preferences and default standards.")
    print()
    
    # Always offer to configure project settings
    print()
    print_section("Next Steps")
    if read_yn("Would you like to run 'run project' now?", default=True):
        print()
        return cmd_project([])
    else:
        print()
        info("You can run 'run project' later to configure your project")
        return 0

def cmd_project(args: List[str]):
    """Project command - configure PROJECT-DEFINITION.vbrief.json"""
    # USER.md gate (#163): mirror the agentic-path gate from
    # skills/deft-directive-build/SKILL.md. Refuse to do work if the user
    # has not yet bootstrapped their preferences -- the message names the
    # resolved path (platform-aware) and redirects to `run bootstrap`.
    gate_exit = _check_user_md_gate()
    if gate_exit is not None:
        return gate_exit
    print_header(f"Deft CLI v{VERSION} - Project Configuration")
    print()
    info("This command creates PROJECT-DEFINITION.vbrief.json, which defines YOUR project:")
    info("  • Tech stack and programming language (narratives)")
    info("  • Project type (CLI, API, Web App, Library, etc.)")
    info("  • Quality standards (test coverage thresholds)")
    info("  • Workflow commands (task check, task test, etc.)")
    print()
    info("This vBRIEF file tells AI assistants how to build and maintain YOUR project.")
    info("It works alongside the general Deft guidelines in ./deft/")
    print()
    
    defaults = get_default_paths()
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['project']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    # Check if we're in a project directory
    if not Path("./deft").is_dir():
        warn("No ./deft directory found. Run 'run install' first or specify a project directory.")
        if read_yn("Install deft in current directory?"):
            return cmd_install(["."])
        else:
            return 1
    
    if 'output_path' not in progress:
        print_section("Output Location")
    project_path_str = _resume_or_ask(progress, prog_file, 'output_path', 'Output',
                                       read_input, "Where to write PROJECT-DEFINITION.vbrief.json", defaults['project'])
    project_file = resolve_path(project_path_str)
    
    # Gather project information
    dir_default = Path.cwd().name
    project_name = _resume_or_ask(progress, prog_file, 'project_name', 'Project',
                                   read_input, "Project name", dir_default)
    
    type_map = {
        "1": "CLI",
        "2": "TUI",
        "3": "REST API",
        "4": "Web App",
        "5": "Library",
        "6": "Other"
    }
    
    valid_type_nums = set(type_map.keys())
    if 'type_selection' not in progress:
        print()
        info("Select project type (comma-separated if multiple):")
        print("  1. CLI (Command-line interface)")
        print("  2. TUI (Terminal UI)")
        print("  3. REST API")
        print("  4. Web App")
        print("  5. Library")
        print("  6. Other")
        while True:
            type_selection = read_input("Selection")
            if not type_selection.strip():
                print_error("Please enter at least one selection (1-6).")
                continue
            nums = [s.strip() for s in type_selection.split(',')]
            if len(nums) != len(set(nums)):
                print_error("Duplicate selections are not allowed.")
                continue
            if all(n in valid_type_nums for n in nums):
                break
            print_error("Please enter numbers between 1 and 6 (comma-separated).")
        progress['type_selection'] = type_selection
        _save_progress(prog_file, progress)
    else:
        type_selection = progress['type_selection']
        info(f"  [resumed] Type: {type_selection}")
    
    type_nums = [s.strip() for s in type_selection.split(',')]
    project_types = []
    custom_type = ""
    
    for num in type_nums:
        if num == "6":
            custom_type = _resume_or_ask(progress, prog_file, 'custom_type', 'Custom type',
                                          read_input, "Enter custom project type")
            project_types.append(custom_type)
        elif num in type_map:
            project_types.append(type_map[num])
    
    project_types_str = ", ".join(project_types)
    
    # Read USER.md defaults to avoid re-asking questions already answered
    # during bootstrap (fix for #7 — double prompting)
    user_defaults = _read_user_defaults(defaults)
    
    # Language selection — pre-fill from USER.md if available
    available_langs = get_available_languages()
    other_num = len(available_langs) + 1
    valid_lang_nums = set(str(i) for i in range(1, other_num + 1))
    if 'lang_selection' not in progress:
        print()
        if user_defaults.get('languages'):
            user_lang_names = user_defaults['languages']
            user_lang_display = ', '.join(user_lang_names)
            info(f"Languages from USER.md: {user_lang_display}")
            info("Select primary programming language(s) (comma-separated):")
            for i, (stem, display) in enumerate(available_langs, 1):
                print(f"  {i}. {display}")
            print(f"  {other_num}. Other")
            while True:
                lang_selection = read_input(
                    f"Selection, or Enter to keep [{user_lang_display}]", ""
                )
                if not lang_selection.strip():
                    break  # Accept USER.md defaults
                nums = [s.strip() for s in lang_selection.split(',')]
                if len(nums) != len(set(nums)):
                    print_error("Duplicate selections are not allowed.")
                    continue
                if all(n in valid_lang_nums for n in nums):
                    break
                print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        else:
            info("Select primary programming language(s) (comma-separated):")
            for i, (stem, display) in enumerate(available_langs, 1):
                print(f"  {i}. {display}")
            print(f"  {other_num}. Other")
            while True:
                lang_selection = read_input("Selection (e.g., 1,3)")
                if not lang_selection.strip():
                    break  # Skip (falls through to Python default)
                nums = [s.strip() for s in lang_selection.split(',')]
                if len(nums) != len(set(nums)):
                    print_error("Duplicate selections are not allowed.")
                    continue
                if all(n in valid_lang_nums for n in nums):
                    break
                print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        progress['lang_selection'] = lang_selection
        progress['_had_user_lang_defaults'] = bool(user_defaults.get('languages'))
        _save_progress(prog_file, progress)
    else:
        lang_selection = progress['lang_selection']
        info(f"  [resumed] Languages: {lang_selection or '(USER.md defaults)'}")
    
    # Parse language selection
    has_user_lang_defaults = user_defaults.get('languages') or progress.get('_had_user_lang_defaults')
    if not lang_selection.strip() and has_user_lang_defaults:
        # Accept USER.md defaults
        user_lang_names = user_defaults.get('languages', [])
        selected_langs = []
        for lang_name in user_lang_names:
            matched = False
            for stem, display in available_langs:
                if display.lower() == lang_name.lower():
                    selected_langs.append((stem, display))
                    matched = True
                    break
            if not matched:
                selected_langs.append((lang_name.lower(), lang_name))
        if not selected_langs:
            selected_langs = [("python", "Python")]
    else:
        lang_nums = [s.strip() for s in lang_selection.split(',')]
        selected_langs = []
        for num in lang_nums:
            try:
                idx = int(num) - 1
                if 0 <= idx < len(available_langs):
                    selected_langs.append(available_langs[idx])
                elif int(num) == other_num:
                    other_lang = _resume_or_ask(progress, prog_file, 'other_lang',
                                                'Other language', read_input, "Enter language name")
                    if other_lang:
                        selected_langs.append((other_lang.lower(), other_lang))
            except ValueError:
                pass
        if not selected_langs:
            selected_langs = [("python", "Python")]
    
    primary_lang = selected_langs[0][1]
    primary_stem = selected_langs[0][0]
    
    # Coverage — pre-fill from USER.md if available
    if 'coverage' not in progress:
        print()
        user_coverage = user_defaults.get('coverage', '85') if user_defaults else None
        while True:
            if user_coverage:
                proj_coverage = read_input(
                    f"Coverage threshold (from USER.md: {user_coverage}%)", user_coverage
                )
            else:
                proj_coverage = read_input("Coverage threshold (default: 85%)", "85")
            if not proj_coverage.strip():
                proj_coverage = user_coverage or "85"
                break
            try:
                val = int(proj_coverage.strip())
                if 1 <= val <= 100:
                    break
            except ValueError:
                pass
            print_error("Please enter a number between 1 and 100.")
        progress['coverage'] = proj_coverage
        _save_progress(prog_file, progress)
    else:
        proj_coverage = progress['coverage']
        info(f"  [resumed] Coverage: {proj_coverage}")
    
    tech_stack = _resume_or_ask(progress, prog_file, 'tech_stack', 'Tech stack',
                                 read_input, "Tech stack details (e.g., 'Flask + SQLAlchemy' or 'React + Next.js')")
    
    # Strategy — pre-fill from USER.md if available
    available_strats = get_available_strategies()
    max_strat = len(available_strats)
    # Compute recommended marker (same logic as cmd_bootstrap)
    default_strat_num = "1"
    for i, (stem, _) in enumerate(available_strats, 1):
        if stem.lower() == "interview":
            default_strat_num = str(i)
            break
    if 'strat_selection' not in progress:
        if max_strat == 0:
            warn("No strategy files found in strategies/ — defaulting to Interview.")
            strat_selection = "1"
        else:
            print()
            print_section("Development Strategy")
            if user_defaults.get('strategy'):
                user_strat_stem = user_defaults['strategy']
                user_strat_display = user_defaults.get('strategy_display', user_strat_stem.title())
                info(f"Default strategy from USER.md: {user_strat_display}")
                info("Does this project need a different strategy?")
                user_pref_strat_num = next(
                    (str(i) for i, (stem, _) in enumerate(available_strats, 1)
                     if stem.lower() == user_strat_stem.lower()),
                    default_strat_num,
                )
                for i, (stem, display) in enumerate(available_strats, 1):
                    desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                    marker = " ★ your default" if str(i) == user_pref_strat_num else ""
                    print(f"  {i}. {display}{marker}")
                    if desc:
                        print(f"     {desc}")
                print()
                info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
                while True:
                    strat_selection = read_input(
                        f"Selection, or Enter to keep [{user_strat_display}]", ""
                    )
                    if not strat_selection.strip():
                        break  # Accept USER.md default
                    try:
                        num = int(strat_selection.strip())
                        if 1 <= num <= max_strat:
                            break
                    except ValueError:
                        pass
                    print_error(f"Please enter a number between 1 and {max_strat}.")
            else:
                info("Select development strategy for this project:")
                for i, (stem, display) in enumerate(available_strats, 1):
                    desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                    marker = " ★ RECOMMENDED" if str(i) == default_strat_num else ""
                    print(f"  {i}. {display}{marker}")
                    if desc:
                        print(f"     {desc}")
                print()
                info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
                while True:
                    strat_selection = read_input("Selection", "1")
                    if not strat_selection.strip():
                        strat_selection = "1"
                        break
                    try:
                        num = int(strat_selection.strip())
                        if 1 <= num <= max_strat:
                            break
                    except ValueError:
                        pass
                    print_error(f"Please enter a number between 1 and {max_strat}.")
        progress['strat_selection'] = strat_selection
        progress['_had_user_strat_default'] = bool(user_defaults.get('strategy'))
        _save_progress(prog_file, progress)
    else:
        strat_selection = progress['strat_selection']
        info(f"  [resumed] Strategy: {strat_selection or '(USER.md default)'}")
    
    # Parse strategy selection
    has_user_strat_default = user_defaults.get('strategy') or progress.get('_had_user_strat_default')
    if not strat_selection.strip() and has_user_strat_default:
        user_strat_stem = user_defaults.get('strategy', 'interview')
        user_strat_display = user_defaults.get('strategy_display', user_strat_stem.title())
        selected_strategy = (user_strat_stem, user_strat_display)
    else:
        try:
            strat_idx = int(strat_selection.strip()) - 1
            if 0 <= strat_idx < len(available_strats):
                selected_strategy = available_strats[strat_idx]
            else:
                selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
        except ValueError:
            selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    strategy_stem, strategy_display = selected_strategy
    
    # Branching preference
    if 'branching' not in progress:
        print()
        print_section("Branching Workflow")
        info("Choose your branching strategy:")
        print("  1. Branch-based ★ RECOMMENDED — create a feature branch for every change")
        print("  2. Trunk-based — commit directly to master/main (common for solo projects)")
        while True:
            branch_selection = read_input("Selection", "1")
            if branch_selection.strip() in ("1", "2"):
                break
            print_error("Please enter 1 or 2.")
        progress['branching'] = branch_selection.strip()
        _save_progress(prog_file, progress)
    else:
        branch_selection = progress['branching']
        info(f"  [resumed] Branching: {branch_selection}")
    
    allow_direct_commits = (branch_selection.strip() == "2")
    
    # Generate project.md
    tech_stack_str = f" - {tech_stack}" if tech_stack else ""
    today = datetime.now().strftime("%Y-%m-%d")
    
    # Build language links and display string
    lang_links = " | ".join([f"[../languages/{s}.md](../languages/{s}.md)" for s, _ in selected_langs])
    lang_names = ", ".join([d for _, d in selected_langs])
    
    # Build vBRIEF PROJECT-DEFINITION structure
    # Narratives hold project identity per RFC D3
    narratives = {
        "Overview": f"{project_name} -- {project_types_str} using {lang_names}",
        "TechStack": f"{project_types_str} using {lang_names}" + (f" - {tech_stack}" if tech_stack else ""),
        "Languages": lang_names,
        "Strategy": f"{strategy_display} (strategies/{strategy_stem}.md)",
        "Coverage": f">={proj_coverage}%",
    }
    if allow_direct_commits:
        narratives["Branching"] = "Allow direct commits to master: true"

    project_definition = {
        "vBRIEFInfo": {
            "version": "0.5",
            "description": f"PROJECT-DEFINITION for {project_name}. Generated by run v{VERSION}.",
            "updated": today,
        },
        "plan": {
            "title": f"{project_name} Project Definition",
            "status": "running",
            "narratives": narratives,
            "items": [],
            "metadata": {
                "generator": f"run v{VERSION}",
                "generatedAt": today,
            },
        },
    }

    project_content = json.dumps(project_definition, indent=2, ensure_ascii=False)
    _atomic_write(project_file, project_content + "\n")

    # Scaffold vBRIEF lifecycle subdirectories (#404).
    # The skill-driven greenfield path creates these; the CLI path must match
    # so `task vbrief:validate` and `task scope:*` work immediately after
    # `run project`.
    vbrief_root = project_file.parent
    for _lifecycle_folder in LIFECYCLE_FOLDERS:
        (vbrief_root / _lifecycle_folder).mkdir(parents=True, exist_ok=True)

    # Record framework version marker for the upgrade gate (#410).
    _write_version_marker(vbrief_root)

    _clear_progress(prog_file)
    
    success(f"Created PROJECT-DEFINITION.vbrief.json at {project_file}")
    print()
    info("PROJECT-DEFINITION.vbrief.json defines your project's identity, tech stack, and quality standards.")
    info("Scope vBRIEFs in vbrief/proposed/ reference this file as the project gestalt.")
    print()
    
    # Prompt to run spec generation
    print()
    print_section("Next Steps")
    info("Generate a scope vBRIEF via AI interview")
    info("The 'spec' command creates a scope vBRIEF in vbrief/proposed/")
    info("for your AI assistant to work from.")
    print()
    if read_yn("Would you like to run 'run spec' now?", default=True):
        print()
        return cmd_spec([])
    else:
        print()
        info("You can run 'run spec' later to generate your specification.")
        return 0

def _read_user_defaults(defaults: dict) -> dict:
    """Read fallback defaults from USER.md if present.
    
    Parses Primary Languages, Default Strategy, and Coverage from USER.md.
    Returns a dict with keys 'languages', 'strategy', 'coverage' where found.
    Returns empty dict if USER.md does not exist.
    """
    user_path_str = defaults.get('user', '')
    if not user_path_str:
        return {}
    user_file = resolve_path(user_path_str)
    if not user_file.exists():
        return {}
    
    result = {}
    try:
        content = user_file.read_text(encoding='utf-8')
        lines = content.split('\n')
        
        # Parse languages: lines starting with "- " after "**Primary Languages**:"
        in_languages = False
        languages = []
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Primary Languages**:'):
                in_languages = True
                continue
            if in_languages:
                if stripped.startswith('- ') and stripped != '- (None specified)':
                    languages.append(stripped[2:].strip())
                elif stripped and not stripped.startswith('- '):
                    in_languages = False
        if languages:
            result['languages'] = languages
        
        # Parse strategy: [Name](../strategies/stem.md)
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Default Strategy**:') and 'strategies/' in stripped:
                start = stripped.index('strategies/') + len('strategies/')
                rest = stripped[start:]
                if '.md' in rest:
                    stem = rest[:rest.index('.md')]
                    if stem:
                        result['strategy'] = stem
                        # Also extract display name from [Name](...)
                        try:
                            bracket_start = stripped.index('[') + 1
                            bracket_end = stripped.index(']')
                            result['strategy_display'] = stripped[bracket_start:bracket_end]
                        except ValueError:
                            pass
                break
        
        # Parse coverage: **Coverage**: ! ≥N% 
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Coverage**:') and '≥' in stripped and '%' in stripped:
                ge_pos = stripped.index('≥') + 1
                pct_pos = stripped.index('%')
                coverage_val = stripped[ge_pos:pct_pos].strip()
                if coverage_val.isdigit():
                    result['coverage'] = coverage_val
                break
    except Exception:
        pass
    
    return result


def _read_project_process(defaults: dict) -> Optional[str]:
    """Read Process value from PROJECT-DEFINITION.vbrief.json or legacy PROJECT.md.
    
    Returns 'Light', 'Full', or None.
    """
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if not project_file.exists():
        return None
    try:
        content = project_file.read_text(encoding='utf-8')
        # Try vBRIEF JSON format first
        if project_file.name.endswith('.vbrief.json'):
            data = json.loads(content)
            process_val = data.get('plan', {}).get('narratives', {}).get('Process', '')
            if process_val.lower() in ('light', 'full'):
                return process_val.capitalize()
            return None
        # Legacy PROJECT.md format
        for line in content.split('\n'):
            stripped = line.strip()
            if stripped.startswith('**Process**:'):
                value = stripped.split(':', 1)[1].strip().rstrip('*').strip()
                if value.lower() in ('light', 'full'):
                    return value.capitalize()
    except Exception:
        pass
    return None

def _read_project_strategy(defaults: dict) -> Optional[str]:
    """Read strategy file stem from PROJECT-DEFINITION.vbrief.json or legacy PROJECT.md.
    
    For vBRIEF format, reads plan.narratives.Strategy which contains:
        "Interview (strategies/interview.md)"
    
    For legacy PROJECT.md, parses the ## Strategy section for a link like:
        Use [Name](path/strategies/stem.md) for this project.
    
    Returns strategy stem (e.g. 'interview', 'discuss') or None.
    """
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if not project_file.exists():
        return None
    try:
        content = project_file.read_text(encoding='utf-8')
        # Try vBRIEF JSON format first
        if project_file.name.endswith('.vbrief.json'):
            data = json.loads(content)
            strategy_val = data.get('plan', {}).get('narratives', {}).get('Strategy', '')
            if 'strategies/' in strategy_val and '.md' in strategy_val:
                start = strategy_val.index('strategies/') + len('strategies/')
                rest = strategy_val[start:]
                stem = rest[:rest.index('.md')]
                if stem:
                    return stem
            return None
        # Legacy PROJECT.md format
        for line in content.split('\n'):
            stripped = line.strip()
            if stripped.startswith('Use [') and 'strategies/' in stripped:
                start = stripped.index('strategies/') + len('strategies/')
                rest = stripped[start:]
                if '.md' in rest:
                    stem = rest[:rest.index('.md')]
                    if stem:
                        return stem
    except Exception:
        pass
    return None

def _slugify(text: str) -> str:
    """Convert text to a URL-friendly slug for vBRIEF filenames.
    
    Strips non-alphanumeric characters, lowercases, and joins with hyphens.
    """
    text = text.lower().strip()
    text = re.sub(r'[^a-z0-9\s_-]', '', text)
    text = re.sub(r'[\s_]+', '-', text)
    text = re.sub(r'-+', '-', text)
    return text[:60].strip('-')  # Cap slug length, remove any trailing hyphen

def cmd_spec(args: List[str]):
    """Spec command - generate scope vBRIEF via interview"""
    # USER.md gate (#163): mirror the agentic-path gate from
    # skills/deft-directive-build/SKILL.md. Refuse to do work if the user
    # has not yet bootstrapped their preferences -- the message names the
    # resolved path (platform-aware) and redirects to `run bootstrap`.
    gate_exit = _check_user_md_gate()
    if gate_exit is not None:
        return gate_exit
    print_header(f"Deft CLI v{VERSION} - Scope vBRIEF Generator")
    print()
    
    defaults = get_default_paths()
    strategy = _read_project_strategy(defaults) or 'interview'
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['vbrief_proposed']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    info("This command creates a scope vBRIEF in vbrief/proposed/ for your AI assistant.")
    if strategy != 'interview':
        info(f"Strategy: {strategy} (from PROJECT-DEFINITION.vbrief.json)")
        info(f"Your AI will follow strategies/{strategy}.md, which chains into")
        info("the sizing gate for scope generation:")
    else:
        info("It follows strategies/interview.md with a sizing gate:")
    info("  \u2022 Light: \u2192 scope vBRIEF in vbrief/proposed/ (embedded requirements)")
    info("  \u2022 Full:  \u2192 scope vBRIEF with rich narratives (approval gate)")
    print()
    info("After creating the file, you'll:")
    info("  1. Give it to your AI assistant")
    info(f"  2. The AI reads strategies/{strategy}.md and follows its workflow")
    info("  3. The AI refines the scope vBRIEF with implementation details")
    info("  4. The AI can then implement the scope")
    print()
    
    # Try to read project name from PROJECT-DEFINITION.vbrief.json (check new default, then legacy)
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if 'spec_name' not in progress:
        spec_name = ""
        if project_file.exists():
            try:
                content = project_file.read_text(encoding='utf-8')
                if project_file.name.endswith('.vbrief.json'):
                    data = json.loads(content)
                    title = data.get('plan', {}).get('title', '')
                    if title and 'Project Definition' in title:
                        spec_name = title.replace(' Project Definition', '').strip()
                    elif title:
                        spec_name = title
                else:
                    # Legacy PROJECT.md format
                    for line in content.split('\n'):
                        if line.startswith('# ') and 'Project Guidelines' in line:
                            spec_name = line.replace('# ', '').replace(' Project Guidelines', '').strip()
                            break
            except (OSError, UnicodeDecodeError, json.JSONDecodeError):
                pass  # Best-effort: fall back to manual name entry
        
        if spec_name:
            info(f"Project name from PROJECT-DEFINITION: {spec_name}")
            if not read_yn("Use this name?", default=True):
                spec_name = read_input("Project name")
        else:
            spec_name = read_input("Project name")
        progress['spec_name'] = spec_name
        _save_progress(prog_file, progress)
    else:
        spec_name = progress['spec_name']
        info(f"  [resumed] Project: {spec_name}")
    
    spec_desc = _resume_or_ask(progress, prog_file, 'spec_desc', 'Description',
                                read_input, "Brief description (1-2 sentences)")
    
    if 'features' not in progress:
        print()
        info("Enter project features (one per line, empty line to finish):")
        features = []
        while True:
            feature = read_input("  Feature")
            if not feature:
                break
            features.append(feature)
        progress['features'] = features
        _save_progress(prog_file, progress)
    else:
        features = progress['features']
        info(f"  [resumed] Features: {len(features)} feature(s)")
    
    # Sizing gate
    if 'sizing' not in progress:
        print()
        print_section("Scope Complexity")
        
        process_override = _read_project_process(defaults)
        if process_override:
            info(f"PROJECT-DEFINITION declares Process: {process_override} -- using that.")
            sizing = process_override
        else:
            recommended = "Light" if len(features) <= 5 else "Full"
            info(f"Based on {len(features)} feature(s), recommended: {recommended}")
            info("  1. Light -- scope vBRIEF with embedded requirements")
            info("  2. Full  -- scope vBRIEF with rich narratives (approval gate)")
            sizing_choice = read_input("Selection", "1" if recommended == "Light" else "2")
            sizing = "Light" if sizing_choice.strip() == "1" else "Full"
        progress['sizing'] = sizing
        _save_progress(prog_file, progress)
    else:
        sizing = progress['sizing']
        info(f"  [resumed] Path: {sizing}")
    
    # Determine output location -- always vbrief/proposed/
    proposed_dir = resolve_path(defaults['vbrief_proposed'])
    today = datetime.now().strftime("%Y-%m-%d")
    slug = _slugify(spec_name)
    output_filename = f"{today}-{slug}.vbrief.json"
    output_file = proposed_dir / output_filename
    
    if not progress.get('_write_ready'):
        if output_file.exists() and "--force" not in args:
            warn(f"{output_file} already exists. Use --force to overwrite.")
            return 1
    progress['_write_ready'] = True
    _save_progress(prog_file, progress)
    
    # Build scope vBRIEF structure
    items = []
    for i, feature in enumerate(features, 1):
        items.append({
            "id": f"F{i}",
            "title": feature,
            "status": "proposed",
        })

    # Build strategy-specific narratives
    narratives = {
        "Overview": spec_desc,
        "Strategy": f"{strategy} ({sizing} path)",
    }
    if sizing == "Full":
        narratives["ProblemStatement"] = ""
        narratives["Goals"] = ""
        narratives["UserStories"] = ""
        narratives["Requirements"] = ""
        narratives["SuccessMetrics"] = ""

    scope_vbrief = {
        "vBRIEFInfo": {
            "version": "0.5",
            "description": f"Scope vBRIEF for {spec_name}. Generated by run v{VERSION}.",
            "updated": today,
        },
        "plan": {
            "title": spec_name,
            "status": "proposed",
            "narratives": narratives,
            "items": items,
            "metadata": {
                "generator": f"run v{VERSION}",
                "generatedAt": today,
                "strategy": strategy,
                "sizing": sizing,
            },
        },
    }

    output_content = json.dumps(scope_vbrief, indent=2, ensure_ascii=False)
    _atomic_write(output_file, output_content + "\n")
    _clear_progress(prog_file)
    
    success(f"Created scope vBRIEF at {output_file}")
    info(f"Path: {sizing}")
    info("Next steps:")
    info(f"  1. Open your AI assistant (Claude, Warp.dev, etc.)")
    info(f"  2. Ask your AI to read {output_file}")
    info(f"  3. The AI reads strategies/{strategy}.md and follows its workflow")
    info("  4. The AI refines the scope vBRIEF with implementation details")
    info("  5. Promote the vBRIEF through lifecycle folders as work progresses")
    return 0

def cmd_install(args: List[str]):
    """Install command - install deft framework in a project"""
    target_dir = Path(args[0]) if args else Path(".")
    
    print_header(f"Deft CLI v{VERSION} - Installation")
    print()
    info("This command installs the Deft framework in your project directory.")
    info("It will create:")
    info("  • ./deft/        - Framework files (guidelines, templates, references)")
    info("  • ./secrets/        - Directory for API keys and credentials (.gitignored)")
    info("  • ./docs/           - Project documentation")
    info("  • Taskfile.yml      - Task automation config (if not present)")
    info("  • .gitignore        - Ensures secrets aren't committed (if not present)")
    print()
    info(f"Target directory: {target_dir.absolute()}")
    print()
    
    if not target_dir.exists():
        error(f"Directory does not exist: {target_dir}")
        return 1
    
    # Change to target directory
    original_dir = Path.cwd()
    os.chdir(target_dir)
    
    try:
        deft_dir = Path("./deft")
        
        # Check if deft already exists
        already_installed = deft_dir.exists()
        if already_installed:
            warn("Deft already installed in this directory.")
            if not read_yn("Reinstall?"):
                # Still offer to run project even if not reinstalling
                print()
                print_section("Next Steps")
                if read_yn("Would you like to run 'run project' now?"):
                    print()
                    return cmd_project([])
                else:
                    return 0
        
        # Copy deft framework
        info("Copying deft framework...")
        script_dir = get_script_dir()
        
        if deft_dir.exists():
            shutil.rmtree(deft_dir)
        
        shutil.copytree(script_dir, deft_dir)

        # #1046 PR-B AC-4: stamp the canonical YAML manifest at
        # ``<install>/VERSION``. Best-effort -- silently degrades on a
        # read-only filesystem. ``project_root`` is the current working
        # directory at this point (we ``os.chdir(target_dir)`` above),
        # so the manifest's ``install_root`` field (#1062) records the
        # relative deposit path (e.g. ``deft``) verbatim.
        _write_install_manifest(
            deft_dir,
            fetched_by="run-install",
            project_root=Path.cwd(),
        )

        # Create project-specific files
        Path("secrets").mkdir(exist_ok=True)
        Path("docs").mkdir(exist_ok=True)
        Path("secrets/.gitkeep").touch()
        
        # Create .gitignore for secrets
        gitignore = Path(".gitignore")
        if not gitignore.exists():
            gitignore.write_text("secrets/*\n!secrets/.gitkeep\n!secrets/*.example\n", encoding='utf-8')
        
        # Create basic Taskfile if it doesn't exist
        taskfile = Path("Taskfile.yml")
        if not taskfile.exists():
            taskfile_content = """version: '3'

tasks:
  default:
    desc: List all tasks
    cmds:
      - task --list
    silent: true

  check:
    desc: Run all pre-commit checks
    cmds:
      - echo "Add your check commands here"
      - task fmt
      - task lint
      - task test

  fmt:
    desc: Format code
    cmds:
      - echo "Add your format command here"

  lint:
    desc: Lint code
    cmds:
      - echo "Add your lint command here"

  test:
    desc: Run tests
    cmds:
      - echo "Add your test command here"

  test:coverage:
    desc: Run tests with coverage
    cmds:
      - echo "Add your coverage command here"
"""
            taskfile.write_text(taskfile_content, encoding='utf-8')
            success("Created Taskfile.yml")
        
        success("Deft installed successfully!")
        print()
        
        # Prompt to run project configuration
        print_section("Next Steps")
        if read_yn("Would you like to run 'run project' now?"):
            print()
            return cmd_project([])
        else:
            print()
            info("You can run these commands later:")
            info("  ./.deft/core/run project     # Configure this project")
            info("  ./.deft/core/run bootstrap   # Set up user preferences")
            return 0
    
    finally:
        os.chdir(original_dir)

def cmd_validate(args: List[str]):
    """Validate command - check deft configuration"""
    print_header(f"Deft CLI v{VERSION} - Validate")
    print()
    info("Validating Deft configuration...")
    print()
    
    script_dir = get_script_dir()
    errors = 0
    
    # Check for required files
    required_files = [
        "main.md",
        "core/user.md",
        "coding/coding.md",
        "REFERENCES.md"
    ]
    
    for file in required_files:
        filepath = script_dir / file
        if filepath.exists():
            success(f"Found: {file}")
        else:
            error(f"Missing: {file}")
            errors += 1
    
    # Check for at least one language file
    lang_dir = script_dir / "languages"
    if lang_dir.exists() and list(lang_dir.glob("*.md")):
        success("Language files present")
    else:
        error("No language files found in languages/")
        errors += 1
    
    # Check for broken links (simple check)
    info("Checking for common broken links...")
    # Note: Python implementation could be more sophisticated
    
    print()
    if errors == 0:
        success("Validation passed! Deft configuration is valid.")
        return 0
    else:
        error(f"Validation failed with {errors} error(s).")
        return 1

# ── #792: shared uv detection helper ──────────────────────────────────
#
# Every deft task script runs via `uv run python ...`, so `uv` is a hard
# runtime dependency. cmd_doctor (#792) and the migrate:preflight task
# (#793) both need a way to detect it. Exposed as a module-level private
# helper so #793 can import it later without duplicating the
# `shutil.which` lookup. Mirrors the agent-side check documented in
# `skills/deft-directive-setup/SKILL.md` § Environment Preflight (the
# `uv on PATH` bullet) including the canonical install URL.

UV_INSTALL_URL = "https://docs.astral.sh/uv/"


def _check_uv_available() -> bool:
    """Return True if `uv` is resolvable on PATH.

    Thin wrapper around :func:`shutil.which` so callers (cmd_doctor,
    migrate:preflight per #793) share a single detection point. Kept
    private to `run` -- if a second consumer lands, promote it to a
    public name in a follow-up.
    """
    return shutil.which("uv") is not None


# === #1335 Epic-1: thin delegation shim (core doctor logic now owned by scripts/doctor.py) ===
# The full implementation (cmd_doctor + _parse_doctor_flags + throttle
# state + install-integrity folding + AGENTS freshness + Taskfile include
# diagnostics + structure checks + --fix + JSON modes) lives in
# scripts/doctor.py as the single source of truth.
# run::cmd_doctor and the Taskfile "doctor:" target are both thin shims.
# Epic-2 (#1336) will retire framework_doctor.py + _maybe_run_framework_doctor.
def cmd_doctor(args: List[str]):
    """Thin shim -- doctor implementation owned by scripts/doctor.py (#1335)."""
    scripts_dir = get_script_dir() / "scripts"
    if str(scripts_dir) not in sys.path:
        sys.path.insert(0, str(scripts_dir))
    import doctor  # type: ignore[import-not-found]
    return doctor.cmd_doctor(args)

